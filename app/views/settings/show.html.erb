<div class="max-w-4xl mx-auto py-8 mb-10">

  <h1 class="text-2xl font-bold mb-6">通知設定</h1>
  <%= render "shared/flash" %>

  <%= form_with model: @user, url: settings_path, method: :patch, data: { turbo: false }, class: "space-y-4" do |f| %>

    <%# 日記通知カード %>
    <div class="bg-white rounded-xl shadow-sm border p-4">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <span class="text-xl">📘</span>
          <div>
            <h2 class="text-base font-bold text-gray-800">日記</h2>
            <p class="text-xs text-gray-500">書き忘れ防止のリマインド通知</p>
          </div>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <%= f.check_box :notify_diary, class: "sr-only peer" %>
          <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
        </label>
      </div>
      <div class="mt-3 flex items-center gap-2">
        <label class="text-sm font-semibold text-gray-600 flex-shrink-0">通知時刻</label>
        <%= f.time_field :notify_diary_time, class: "border rounded-lg px-3 py-2 h-[42px] w-full bg-white text-gray-800" %>
      </div>
    </div>

    <%# 家計簿通知カード %>
    <div class="bg-white rounded-xl shadow-sm border p-4">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <span class="text-xl">💴</span>
          <div>
            <h2 class="text-base font-bold text-gray-800">家計簿</h2>
            <p class="text-xs text-gray-500">入力リマインド通知</p>
          </div>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <%= f.check_box :notify_entry, class: "sr-only peer" %>
          <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
        </label>
      </div>
      <div class="mt-3 flex items-center gap-2">
        <label class="text-sm font-semibold text-gray-600 flex-shrink-0">通知時刻</label>
        <%= f.time_field :notify_entry_time, class: "border rounded-lg px-3 py-2 h-[42px] w-full bg-white text-gray-800" %>
      </div>
    </div>

    <%# 体調ログ通知カード %>
    <div class="bg-white rounded-xl shadow-sm border p-4">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <span class="text-xl">⚖️</span>
          <div>
            <h2 class="text-base font-bold text-gray-800">体調ログ</h2>
            <p class="text-xs text-gray-500">毎日の体重・体調記録のリマインド</p>
          </div>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <%= f.check_box :notify_health, class: "sr-only peer" %>
          <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
        </label>
      </div>
      <div class="mt-3 flex items-center gap-2">
        <label class="text-sm font-semibold text-gray-600 flex-shrink-0">通知時刻</label>
        <%= f.time_field :notify_health_time, class: "border rounded-lg px-3 py-2 h-[42px] w-full bg-white text-gray-800" %>
      </div>
    </div>

    <%# 読書ログ通知カード %>
    <div class="bg-white rounded-xl shadow-sm border p-4">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <span class="text-xl">📚</span>
          <div>
            <h2 class="text-base font-bold text-gray-800">読書ログ</h2>
            <p class="text-xs text-gray-500">読書中の本がある場合のみ通知</p>
          </div>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <%= f.check_box :notify_books, class: "sr-only peer" %>
          <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
        </label>
      </div>
      <div class="mt-3 flex items-center gap-2">
        <label class="text-sm font-semibold text-gray-600 flex-shrink-0">通知時刻</label>
        <%= f.time_field :notify_books_time, class: "border rounded-lg px-3 py-2 h-[42px] w-full bg-white text-gray-800" %>
      </div>
    </div>

    <%# スケジュール通知カード %>
    <div class="bg-white rounded-xl shadow-sm border p-4">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <span class="text-xl">🗓</span>
          <div>
            <h2 class="text-base font-bold text-gray-800">スケジュール</h2>
            <p class="text-xs text-gray-500">予定の開始前に通知</p>
          </div>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <%= f.check_box :notify_schedule, class: "sr-only peer" %>
          <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
        </label>
      </div>
      <div class="mt-3 flex items-center gap-2">
        <label class="text-sm font-semibold text-gray-600 flex-shrink-0">何分前</label>
        <%= f.number_field :notify_schedule_before, min: 1, max: 120,
              class: "border rounded-lg px-3 py-2 h-[42px] w-full bg-white text-gray-800", placeholder: "10" %>
        <span class="text-sm text-gray-500 flex-shrink-0">分前</span>
      </div>
    </div>

    <div class="pt-2">
      <%= f.submit "設定を保存", class: ui_button_classes(variant: :primary, size: :lg) %>
    </div>

  <% end %>
</div>
