<div class="max-w-4xl mx-auto py-8 mb-10">

  <h1 class="text-2xl font-bold mb-6">通知設定</h1>
  <%= render "shared/flash" %>

  <%= form_with model: @user, url: settings_path, method: :patch, data: { turbo: false }, class: "space-y-4" do |f| %>

    <%# 通知カード定義: [トグル属性, 時刻/分前属性, 絵文字, 機能名, 説明, 入力ラベル, 入力種別] %>
    <%
      notification_items = [
        { toggle: :notify_diary,    time_attr: :notify_diary_time,         emoji: "📘", name: "日記",         desc: "書き忘れ防止のリマインド通知",         time_label: "通知時刻", input_type: :time   },
        { toggle: :notify_entry,    time_attr: :notify_entry_time,         emoji: "💴", name: "家計簿",       desc: "入力リマインド通知",                   time_label: "通知時刻", input_type: :time   },
        { toggle: :notify_health,   time_attr: :notify_health_time,        emoji: "⚖️", name: "体調ログ",     desc: "毎日の体重・体調記録のリマインド",     time_label: "通知時刻", input_type: :time   },
        { toggle: :notify_books,    time_attr: :notify_books_time,         emoji: "📚", name: "読書ログ",     desc: "読書中の本がある場合のみ通知",         time_label: "通知時刻", input_type: :time   },
        { toggle: :notify_schedule, time_attr: :notify_schedule_before,    emoji: "🗓", name: "スケジュール", desc: "予定の開始前に通知",                   time_label: "何分前",   input_type: :number },
      ]
    %>

    <% notification_items.each do |item| %>
      <div class="bg-white rounded-xl shadow-sm border p-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="text-xl"><%= item[:emoji] %></span>
            <div>
              <h2 class="text-base font-bold text-gray-800"><%= item[:name] %></h2>
              <p class="text-xs text-gray-500"><%= item[:desc] %></p>
            </div>
          </div>
          <label class="relative inline-flex items-center cursor-pointer">
            <%= f.check_box item[:toggle], class: "sr-only peer" %>
            <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
          </label>
        </div>
        <div class="mt-3 flex items-center gap-2">
          <label class="text-sm font-semibold text-gray-600 flex-shrink-0"><%= item[:time_label] %></label>
          <% if item[:input_type] == :time %>
            <%= f.time_field item[:time_attr], class: [ApplicationHelper::INPUT_CLASS, "h-[42px] bg-white text-gray-800"].join(" ") %>
          <% else %>
            <%= f.number_field item[:time_attr], min: 1, max: 120, placeholder: "10",
                  class: [ApplicationHelper::INPUT_CLASS, "h-[42px] bg-white text-gray-800"].join(" ") %>
            <span class="text-sm text-gray-500 flex-shrink-0">分前</span>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="pt-2">
      <%= f.submit "設定を保存", class: ui_button_classes(variant: :primary, size: :lg) %>
    </div>

  <% end %>
</div>
