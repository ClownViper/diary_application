<div class="max-w-4xl mx-auto pb-8 mb-10">

  <h1 class="text-2xl font-bold mb-6"><%= t("settings.title") %></h1>
  <%= render "shared/flash" %>

  <div class="bg-white rounded-xl shadow-sm border p-4 mb-4">
    <p class="text-sm text-gray-600 mb-3"><%= t("settings.push_permission_desc") %></p>
    <button id="enable-push-btn" type="button" class="<%= ui_button_classes(variant: :primary) %>">
      <%= t("settings.push_permission_btn") %>
    </button>
  </div>

  <%= form_with model: @user, url: settings_path, method: :patch, data: { turbo: false }, class: "space-y-4" do |f| %>

    <%# Notification card definitions %>
    <%
      notification_items = [
        { toggle: :notify_diary,    time_attr: :notify_diary_time,         key: "diary",    input_type: :time   },
        { toggle: :notify_entry,    time_attr: :notify_entry_time,         key: "entry",    input_type: :time   },
        { toggle: :notify_health,   time_attr: :notify_health_time,        key: "health",   input_type: :time   },
        { toggle: :notify_books,    time_attr: :notify_books_time,         key: "books",    input_type: :time   },
        { toggle: :notify_schedule, time_attr: :notify_schedule_before,    key: "schedule", input_type: :number },
      ]
    %>

    <% notification_items.each do |item| %>
      <div class="bg-white rounded-xl shadow-sm border p-4">
        <div class="grid grid-cols-2 md:grid-cols-3 items-center gap-x-4 gap-y-2">

          <%# Heading: mobile col1/row1, desktop col1/row1 %>
          <div class="col-start-1 row-start-1 md:col-start-1 md:row-start-1 flex items-center gap-2">
            <div>
              <h2 class="text-base font-bold text-gray-800"><%= t("settings.notification_items.#{item[:key]}.name") %></h2>
              <p class="text-xs text-gray-500"><%= t("settings.notification_items.#{item[:key]}.desc") %></p>
            </div>
          </div>

          <%# Time input: mobile col1/row2, desktop col2/row1 %>
          <div class="col-start-1 row-start-2 md:col-start-2 md:row-start-1 flex items-center gap-2">
            <label class="text-sm font-semibold text-gray-600 flex-shrink-0"><%= t("settings.notification_items.#{item[:key]}.time_label") %></label>
            <% if item[:input_type] == :time %>
              <%= f.time_field item[:time_attr], class: [ApplicationHelper::INPUT_CLASS, "h-[42px] bg-white text-gray-800 appearance-none"].join(" ") %>
            <% else %>
              <%= f.number_field item[:time_attr], min: 1, max: 120, placeholder: "10",
                    class: "w-20 border rounded-lg px-3 h-[42px] bg-white text-gray-800 appearance-none focus:outline-none focus:ring-2 focus:ring-slate-300 focus:border-slate-400" %>
              <span class="text-sm text-gray-500 flex-shrink-0"><%= t("settings.minutes_before_suffix") %></span>
            <% end %>
          </div>

          <%# Toggle: mobile col2/row1-2 (centered), desktop col3/row1 %>
          <div class="col-start-2 row-start-1 row-span-2 md:col-start-3 md:row-start-1 md:row-span-1
                      flex items-center justify-end md:justify-center self-center">
            <label class="relative inline-flex items-center cursor-pointer">
              <%= f.check_box item[:toggle], class: "sr-only peer" %>
              <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-slate-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-slate-600"></div>
            </label>
          </div>

        </div>
      </div>
    <% end %>

    <div class="pt-2">
      <%= f.submit t("settings.save"), class: ui_button_classes(variant: :primary, size: :lg) %>
    </div>

  <% end %>
</div>
