<div class="max-w-4xl mx-auto pb-8 mb-10">

  <%= render "shared/page_header", title: t("categories.index.title"), button_label: t("shared.new_add"), button_path: new_category_path %>

  <div class="bg-white rounded-xl border shadow-sm overflow-hidden">

    <!-- Table header (hidden on mobile) -->
    <div class="hidden md:grid grid-cols-4 bg-gray-100 px-4 py-2 text-sm font-semibold text-gray-700">
      <div><%= t("categories.index.col_name") %></div>
      <div><%= t("categories.index.col_color") %></div>
      <div><%= t("categories.index.col_count") %></div>
      <div class="text-center"><%= t("categories.index.col_actions") %></div>
    </div>

    <%= render "shared/empty_state", message: t("categories.index.empty"), inline: true if @categories.empty? %>

    <% @categories.each do |category| %>

      <!-- Desktop: 4-column grid / Mobile: card style -->
      <div class="px-4 py-4 border-b hover:bg-gray-50 transition">

        <!-- Mobile: category name, color, count in a row -->
        <div class="flex md:hidden items-center justify-between mb-3">

          <!-- Left: category name -->
          <div class="font-medium text-gray-900">
            <%= category.name %>
          </div>

          <!-- Center: color swatch -->
          <div class="flex items-center">
            <div class="w-5 h-5 rounded-full"
                 style="background-color: <%= category.color %>;">
            </div>
          </div>

          <!-- Right: usage count -->
          <div class="text-gray-700 text-sm">
            <%= t("categories.index.count_suffix", count: category.expenses_count) %>
          </div>

        </div>

        <!-- Desktop: 4-column grid -->
        <div class="hidden md:grid grid-cols-4 items-center">
          <div class="font-medium text-gray-900"><%= category.name %></div>

          <div>
            <div class="w-5 h-5 rounded-full"
                 style="background-color: <%= category.color %>;">
            </div>
          </div>

          <div class="text-gray-700">
            <%= t("categories.index.count_suffix", count: category.expenses_count) %>
          </div>

          <!-- Desktop action buttons -->
          <div class="text-right space-x-2 text-sm">
            <%= ui_link_button t("shared.edit"), edit_category_path(category), variant: :secondary, size: :md %>

            <%= button_to t("shared.delete"),
                  category_path(category),
                  method: :delete,
                  data: { confirm: t("shared.delete_confirm") },
                  class: ui_button_classes(variant: :danger, size: :md),
                  form: { class: "inline" } %>
          </div>
        </div>

        <!-- Mobile: action buttons in a row -->
        <div class="flex md:hidden gap-2 mt-2">

          <%= link_to t("shared.edit"), edit_category_path(category),
                class: [ui_button_classes(variant: :secondary, size: :sm), "block w-full text-center flex-1"].join(" ") %>

          <%= button_to t("shared.delete"),
                category_path(category),
                method: :delete,
                form: { class: "flex-1" },
                data: { confirm: t("shared.delete_confirm") },
                class: [ui_button_classes(variant: :danger, size: :sm), "block w-full text-center"].join(" ") %>

        </div>
      </div>
    <% end %>
  </div>

  <%= render "shared/pagination", collection: @categories %>

  <p class="text-sm text-gray-500 mt-4">
    <%= t("categories.index.note") %>
  </p>

</div>
