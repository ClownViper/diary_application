<%= render layout: "shared/form_card" do %>
  <%= form_with model: category, class: "space-y-6" do |f| %>
    <%= render "shared/form_errors", resource: category %>

    <div class="!mt-2">
      <%= render "shared/form_field", form: f, attr: :name, field_label: "カテゴリ名",
            field_options: { placeholder: "例：食費" } %>
    </div>

    <div>
      <%= f.label :color, "表示カラー", class: ApplicationHelper::LABEL_CLASS %>

      <div class="flex gap-3 mb-3">
        <% ["#EF4444", "#F97316", "#FACC15", "#22C55E", "#3B82F6", "#8B5CF6", "#EC4899", "#6B7280"].each do |c| %>
          <button type="button"
                  class="w-7 h-7 rounded-full cursor-pointer border hover:scale-110 transition"
                  style="background-color: <%= c %>;"
                  onclick="document.getElementById('color-input').value = '<%= c %>'">
          </button>
        <% end %>
      </div>

      <%= render "shared/form_field", form: f, attr: :color, hide_label: true,
            field_options: { id: "color-input", placeholder: "#3B82F6" } %>
    </div>

    <div>
      <%= f.submit "保存", class: ui_button_classes(variant: :primary, size: :lg) %>
    </div>
  <% end %>
<% end %>