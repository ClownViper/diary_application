<div class="max-w-4xl mx-auto pb-8 mb-10">

  <%= render "shared/page_header", title: t("schedules.index.title"), button_label: t("shared.new_record"), button_path: new_schedule_path %>

  <!-- Search form -->
  <div class="mb-6 bg-white p-4 rounded-xl shadow">
    <%= form_with url: schedules_path, method: :get, local: true, class: "grid grid-cols-1 md:grid-cols-3 gap-4" do |f| %>

      <div>
        <label class="<%= ApplicationHelper::SEARCH_LABEL_CLASS %>"><%= t("shared.search_form.keyword") %></label>
        <%= f.text_field :q, value: params[:q],
              placeholder: t("schedules.index.search_keyword_placeholder"),
              class: ApplicationHelper::INPUT_CLASS %>
      </div>

      <div>
        <label class="<%= ApplicationHelper::SEARCH_LABEL_CLASS %>"><%= t("shared.search_form.date") %></label>
        <%= f.date_field :date, value: params[:date],
              placeholder: " ",
              class: [ApplicationHelper::INPUT_CLASS, "h-[42px] bg-white text-gray-800 appearance-none"].join(" ") %>
      </div>

      <div class="flex items-end">
        <%= f.submit t("shared.search"), class: [ui_button_classes(variant: :primary, size: :md), "w-full"].join(" ") %>
      </div>

    <% end %>
  </div>

  <!-- Table-style list -->
  <div class="bg-white rounded-xl shadow overflow-hidden">

    <div class="hidden md:grid grid-cols-4 bg-gray-100 px-4 py-2 text-sm font-semibold text-gray-700">
      <div><%= t("schedules.index.col_date") %></div>
      <div><%= t("schedules.index.col_title") %></div>
      <div><%= t("schedules.index.col_time") %></div>
      <div class="text-right"><%= t("schedules.index.col_memo") %></div>
    </div>

    <% @schedules.each do |schedule| %>
      <%= link_to schedule_path(schedule),
            class: "grid grid-cols-1 md:grid-cols-4 gap-1 px-4 py-3 border-b hover:bg-gray-50 transition" do %>

        <div class="text-gray-600">
          <%= format_date(schedule.date) %>
        </div>

        <div class="font-medium text-gray-900 truncate">
          <%= schedule.title %>
        </div>

        <div class="text-gray-700">
          <% if schedule.start_time.present? || schedule.end_time.present? %>
            <%= schedule.start_time&.strftime("%H:%M") || "--:--" %>
            〜
            <%= schedule.end_time&.strftime("%H:%M") || "--:--" %>
          <% else %>
            —
          <% end %>
        </div>

        <div class="text-right text-gray-500 truncate">
          <%= schedule.memo.present? ? schedule.memo.truncate(20) : "—" %>
        </div>

      <% end %>
    <% end %>

    <%= render "shared/empty_state", message: t("schedules.index.empty"), inline: true if @schedules.empty? %>

  </div>
  <%= render "shared/pagination", collection: @schedules %>
</div>
