<%= render "shared/back_link", back_path: schedules_path %>

<div class="max-w-4xl mx-auto pb-10 mb-10">

  <div class="bg-white p-6 rounded-xl shadow leading-relaxed text-gray-800 mb-8">

    <p class="text-gray-500 text-sm">
      <%= format_date(@schedule.date) %>
    </p>

    <h1 class="text-2xl font-bold text-gray-800 mb-4">
      <%= @schedule.title %>
    </h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
      <!-- 開始時刻 -->
      <div class="bg-gray-50 p-4 rounded-lg">
        <p class="text-sm text-gray-500 mb-1">開始時刻</p>
        <p class="text-2xl font-bold text-gray-900">
          <%= @schedule.start_time.present? ? @schedule.start_time.strftime("%H:%M") : "—" %>
        </p>
      </div>

      <!-- 終了時刻 -->
      <div class="bg-gray-50 p-4 rounded-lg">
        <p class="text-sm text-gray-500 mb-1">終了時刻</p>
        <p class="text-2xl font-bold text-gray-900">
          <%= @schedule.end_time.present? ? @schedule.end_time.strftime("%H:%M") : "—" %>
        </p>
      </div>
    </div>

    <%= render "shared/memo_block", content: @schedule.memo %>

    <div class="flex gap-4 pt-4">
      <%= render "shared/record_actions",
            edit_path: edit_schedule_path(@schedule),
            destroy_path: schedule_path(@schedule) %>
    </div>

  </div>

</div>
