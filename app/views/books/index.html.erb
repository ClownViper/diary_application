<div class="max-w-4xl mx-auto pb-8 mb-10">

  <%= render "shared/page_header", title: t("books.index.title"), button_label: t("shared.new_record"), button_path: new_book_path %>

  <!-- Search form -->
  <div class="mb-6 bg-white p-4 rounded-xl shadow">
    <%= form_with url: books_path, method: :get, local: true, class: "grid grid-cols-1 md:grid-cols-3 gap-4" do |f| %>

      <div>
        <label class="<%= ApplicationHelper::SEARCH_LABEL_CLASS %>"><%= t("shared.search_form.keyword") %></label>
        <%= f.text_field :q, value: params[:q],
              placeholder: t("books.index.search_keyword_placeholder"),
              class: ApplicationHelper::INPUT_CLASS %>
      </div>

      <div>
        <label class="<%= ApplicationHelper::SEARCH_LABEL_CLASS %>"><%= t("books.index.search_status") %></label>
        <%= f.select :status,
              Book.status_select_options,
              { include_blank: t("shared.search_form.all") },
              class: [ApplicationHelper::INPUT_CLASS, "bg-white text-gray-700 appearance-none"].join(" ") %>
      </div>

      <div class="flex items-end">
        <%= f.submit t("shared.search"), class: [ui_button_classes(variant: :primary, size: :md), "w-full"].join(" ") %>
      </div>

    <% end %>
  </div>

  <!-- Card list -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <% @books.each do |book| %>
      <%= link_to book_path(book),
            class: "bg-white rounded-xl shadow hover:shadow-md transition p-4 flex gap-4" do %>

        <%= render "shared/thumbnail", attachment: book.cover, size_class: "w-20 h-28" %>

        <div class="flex flex-col min-w-0">
          <p class="font-bold text-gray-800 truncate"><%= book.title %></p>
          <p class="text-sm text-gray-500"><%= book.author.presence || t("shared.unknown_author") %></p>

          <span class="mt-1 inline-block px-2 py-0.5 rounded-full text-xs font-semibold w-fit
            <%= case book.status
                when 'unread' then 'bg-gray-100 text-gray-600'
                when 'reading' then 'bg-blue-100 text-blue-700'
                when 'finished' then 'bg-green-100 text-green-700'
                end %>">
            <%= book.status_label %>
          </span>

          <% if book.memo.present? %>
            <p class="text-xs text-gray-500 mt-1 truncate"><%= book.memo.truncate(30) %></p>
          <% end %>
        </div>

      <% end %>
    <% end %>
  </div>

  <%= render "shared/empty_state", message: t("books.index.empty") if @books.empty? %>
  <%= render "shared/pagination", collection: @books %>

</div>
