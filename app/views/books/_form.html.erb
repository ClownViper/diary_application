<%= render layout: "shared/form_card" do %>
  <%= form_with model: book, data: { turbo: false }, class: "space-y-6" do |f| %>
    <%= render "shared/form_errors", resource: book %>

    <div class="!mt-2">
      <%= render "shared/form_field", form: f, attr: :title, field_label: "書籍タイトル" %>
    </div>

    <%= render "shared/form_field", form: f, attr: :author, field_label: "著者" %>

    <!-- ステータス -->
    <div>
      <%= f.label :status, "ステータス", class: ApplicationHelper::LABEL_CLASS %>
      <%= f.select :status,
            Book::STATUS_LABELS.map { |k, v| [v, k] },
            {},
            class: ApplicationHelper::INPUT_CLASS %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <%= render "shared/form_field", form: f, attr: :started_on, field_label: "読み始め日", field_type: :date_field %>

      <%= render "shared/form_field", form: f, attr: :finished_on, field_label: "読了日", field_type: :date_field %>
    </div>

    <%= render "shared/form_field", form: f, attr: :memo, field_label: "感想", field_type: :text_area,
          field_options: { rows: 5, maxlength: 300, placeholder: "300文字以内" } %>

    <!-- 表紙画像 -->
    <div>
      <%= f.label :cover, "表紙画像", class: ApplicationHelper::LABEL_CLASS %>
      <%= f.file_field :cover, accept: "image/png,image/jpeg,image/webp",
            class: ApplicationHelper::FILE_INPUT_CLASS %>
      <% if book.cover.attached? %>
        <div class="mt-2">
          <%= image_tag book.cover, class: "w-20 h-28 object-cover rounded" %>
        </div>
      <% end %>
    </div>

    <div>
      <%= f.submit "保存", class: ui_button_classes(variant: :primary, size: :lg) %>
    </div>
  <% end %>
<% end %>
