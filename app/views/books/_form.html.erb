<%= render layout: "shared/form_card" do %>
  <%= form_with model: book, data: { turbo: false }, class: "space-y-6" do |f| %>

    <%# Barcode scan button %>
    <div class="!mt-2">
      <button type="button" onclick="openBookScanner()"
              class="inline-flex items-center gap-2 px-4 py-2 border border-slate-400 text-slate-600
                     rounded-lg text-sm font-medium hover:bg-slate-50 transition">
        📷 <%= t("books.scanner.button") %>
      </button>
    </div>

    <div>
      <%= render "shared/form_field", form: f, attr: :title %>
    </div>

    <%= render "shared/form_field", form: f, attr: :author %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <%= render "shared/form_field", form: f, attr: :isbn,
            field_options: { inputmode: "numeric", placeholder: t("books.form.isbn_placeholder") } %>
      <%= render "shared/form_field", form: f, attr: :purchase_price, field_type: :number_field,
            field_options: { min: 0, inputmode: "numeric", placeholder: t("books.form.price_placeholder") } %>
    </div>

    <!-- Status -->
    <div>
      <%= f.label :status, t("activerecord.attributes.book.status"), class: ApplicationHelper::LABEL_CLASS %>
      <%= f.select :status,
            Book.status_select_options,
            {},
            class: ApplicationHelper::INPUT_CLASS %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <%= render "shared/form_field", form: f, attr: :started_on, field_type: :date_field,
            field_options: { class: [ApplicationHelper::INPUT_CLASS, "h-[42px] bg-white appearance-none md:max-w-[66%]"].join(" ") } %>
      <%= render "shared/form_field", form: f, attr: :finished_on, field_type: :date_field,
            field_options: { class: [ApplicationHelper::INPUT_CLASS, "h-[42px] bg-white appearance-none md:max-w-[66%]"].join(" ") } %>
    </div>

    <%= render "shared/form_field", form: f, attr: :memo, field_type: :text_area,
          field_options: { rows: 5, maxlength: 300, placeholder: t("books.form.memo_placeholder") } %>

    <!-- Cover image with filename display -->
    <div>
      <%= f.label :cover, t("activerecord.attributes.book.cover"), class: ApplicationHelper::LABEL_CLASS %>
      <div class="flex items-center gap-3">
        <label class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-300 rounded-lg cursor-pointer hover:bg-gray-50 transition text-sm text-gray-700 font-medium">
          <%= t("shared.file_select") %>
          <%= f.file_field :cover, accept: "image/png,image/jpeg,image/webp", class: "hidden",
                onchange: "this.closest('div').querySelector('.file-name').textContent = this.files[0]?.name || ''" %>
        </label>
        <span class="file-name text-sm text-gray-500"></span>
      </div>
      <% if book.cover.attached? %>
        <div class="mt-2">
          <%= image_tag book.cover, class: "w-20 h-28 object-cover rounded" %>
        </div>
      <% end %>
    </div>

    <div>
      <%= f.submit t("shared.save"), class: ui_button_classes(variant: :primary, size: :lg) %>
    </div>
  <% end %>
<% end %>
