<%= render "shared/back_link", back_path: books_path %>

<div class="max-w-4xl mx-auto pb-10 mb-10">

  <div class="bg-white p-6 rounded-xl border shadow-sm leading-relaxed text-gray-800 mb-8">

    <div class="flex gap-6 mb-4">
      <% if @book.cover.attached? %>
        <%= image_tag @book.cover, class: "w-32 h-44 object-cover rounded-lg flex-shrink-0" %>
      <% else %>
        <div class="w-32 h-44 bg-gray-200 rounded-lg flex items-center justify-center text-gray-400 text-sm flex-shrink-0">
          <%= t("shared.no_image") %>
        </div>
      <% end %>

      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%= @book.title %></h1>
        <p class="text-gray-500"><%= @book.author.presence || t("shared.unknown_author") %></p>

        <span class="mt-2 inline-block px-2 py-1 rounded-full text-xs font-semibold
          <%= case @book.status
              when 'unread' then 'bg-gray-100 text-gray-600'
              when 'reading' then 'bg-blue-100 text-blue-700'
              when 'finished' then 'bg-green-100 text-green-700'
              end %>">
          <%= @book.status_label %>
        </span>

        <div class="mt-3 text-sm text-gray-600 space-y-1">
          <% if @book.started_on.present? %>
            <p><%= t("books.show.started_on", date: format_date(@book.started_on)) %></p>
          <% end %>
          <% if @book.finished_on.present? %>
            <p><%= t("books.show.finished_on", date: format_date(@book.finished_on)) %></p>
          <% end %>
          <% if @book.purchase_price.present? %>
            <p><%= Book.human_attribute_name(:purchase_price) %>: ¥<%= number_with_delimiter(@book.purchase_price) %></p>
          <% end %>
          <% if @book.isbn.present? %>
            <p class="text-gray-400">ISBN: <%= @book.isbn %></p>
          <% end %>
        </div>
      </div>
    </div>

    <%= render "shared/memo_block", content: @book.memo, empty_message: t("books.show.no_review") %>

    <div class="flex gap-4 pt-4">
      <%= render "shared/record_actions",
            edit_path: edit_book_path(@book),
            destroy_path: book_path(@book) %>
    </div>

  </div>

</div>
