<div class="max-w-4xl mx-auto pb-8 mb-10">

  <%= render "shared/page_header", title: t("expenses.index.title"), button_label: t("shared.new_record"), button_path: new_expense_path %>

  <!-- Search form -->
  <div class="mb-6 bg-white p-4 rounded-xl border shadow-sm">
    <%= form_with url: expenses_path, method: :get, local: true, class: "grid grid-cols-1 md:grid-cols-4 gap-4" do |f| %>

      <div>
        <label class="<%= ApplicationHelper::SEARCH_LABEL_CLASS %>"><%= t("shared.search_form.keyword") %></label>
        <%= f.text_field :q, value: params[:q],
              placeholder: t("expenses.index.search_keyword_placeholder"),
              class: ApplicationHelper::INPUT_CLASS %>
      </div>

      <div>
        <label class="<%= ApplicationHelper::SEARCH_LABEL_CLASS %>"><%= t("shared.search_form.date") %></label>
        <%= f.date_field :date,
              placeholder: " ",
              class: [ApplicationHelper::INPUT_CLASS, "h-[42px] bg-white text-gray-800 appearance-none"].join(" ") %>
      </div>

      <div>
        <label class="<%= ApplicationHelper::SEARCH_LABEL_CLASS %>"><%= t("shared.search_form.all") %></label>
        <%= f.select :category_id,
              options_from_collection_for_select(@categories, :id, :name, params[:category_id]),
              { include_blank: t("shared.search_form.all") },
              class: [ApplicationHelper::INPUT_CLASS, "bg-white text-gray-700 appearance-none"].join(" ") %>
      </div>

      <div class="flex items-end">
        <%= f.submit t("shared.search"), class: [ui_button_classes(variant: :primary, size: :md), "w-full"].join(" ") %>
      </div>

    <% end %>
  </div>

  <!-- Table-style list -->
  <div class="bg-white rounded-xl border shadow-sm overflow-hidden">

    <div class="hidden md:grid grid-cols-4 bg-gray-100 px-4 py-2 text-sm font-semibold text-gray-700">
      <div><%= t("expenses.index.col_title") %></div>
      <div><%= t("expenses.index.col_category") %></div>
      <div><%= t("expenses.index.col_date") %></div>
      <div class="text-right"><%= t("expenses.index.col_amount") %></div>
    </div>

    <% @expenses.each do |expense| %>
      <%= link_to expense_path(expense),
            class: "grid grid-cols-1 md:grid-cols-4 gap-1 px-4 py-3 border-b hover:bg-gray-50 transition" do %>

        <div class="font-medium text-gray-900 truncate">
          <%= expense.name %>
        </div>

        <div class="min-w-0">
          <% if expense.category&.color.present? %>
            <span class="inline-block max-w-full truncate px-2 py-1 rounded-full text-white text-xs font-semibold"
                  style="background-color: <%= expense.category.color %>;">
              <%= expense.category.name %>
            </span>
          <% else %>
            <span class="inline-block max-w-full truncate px-2 py-1 rounded-full bg-gray-200 text-gray-700 text-xs font-semibold">
              <%= expense.category&.name.presence || t("shared.uncategorized") %>
            </span>
          <% end %>
        </div>

        <div class="text-gray-600">
          <%= format_date(expense.date) %>
        </div>

        <div class="text-right font-bold text-gray-800">
          ¥<%= number_with_delimiter(expense.amount) %>
        </div>

      <% end %>
    <% end %>

    <%= render "shared/empty_state", message: t("expenses.index.empty"), inline: true if @expenses.empty? %>

  </div>
  <%= render "shared/pagination", collection: @expenses %>
</div>
