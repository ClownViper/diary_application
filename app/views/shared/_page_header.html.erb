<%# locals: (title:, button_label: nil, button_path: nil, secondary_button_label: nil, secondary_button_path: nil) %>
<div class="flex flex-wrap justify-between items-center gap-2 mb-4">
  <h1 class="text-2xl font-bold"><%= title %></h1>
  <div class="flex gap-2 w-full md:w-auto">
    <% if secondary_button_label.present? && secondary_button_path.present? %>
      <%= ui_link_button secondary_button_label, secondary_button_path, variant: :secondary, size: :md %>
    <% end %>
    <% if button_label.present? && button_path.present? %>
      <%= ui_link_button button_label, button_path, variant: :primary, size: :md %>
    <% end %>
  </div>
</div>
<%# Flash message displayed below the page header %>
<%= render "shared/flash" %>
