<%# locals: (back_path:, back_label: nil, mb_class: "mb-6") %>
<%
  back_label = local_assigns.fetch(:back_label) { t("shared.back_to_index") }
%>
<%# Aligned to the shared max-w-4xl content width %>
<div class="max-w-4xl mx-auto <%= mb_class %>">
  <%= ui_back_link back_label, back_path %>
</div>
<%# Flash message aligned to card width %>
<div class="max-w-4xl mx-auto">
  <%= render "shared/flash" %>
</div>
