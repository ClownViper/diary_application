<%# locals: (collection:) %>
<% if collection.total_pages > 1 %>
  <%
    base_params = request.query_parameters.except("page")
    btn_base    = "px-3 py-2 rounded-lg text-sm font-medium transition"
    btn_active  = "#{btn_base} bg-white border text-gray-700 hover:bg-gray-50"
    btn_disabled = "#{btn_base} bg-gray-100 text-gray-400 cursor-not-allowed"
  %>

  <div class="flex flex-wrap items-center justify-center gap-2 mt-6">

    <%# First page %>
    <% if collection.first_page? %>
      <span class="<%= btn_disabled %>">|&lt;</span>
    <% else %>
      <%= link_to url_for(base_params.merge("page" => 1)), class: btn_active do %>|&lt;<% end %>
    <% end %>

    <%# Previous page %>
    <% if collection.first_page? %>
      <span class="<%= btn_disabled %>">&lt;</span>
    <% else %>
      <%= link_to url_for(base_params.merge("page" => collection.current_page - 1)), class: btn_active do %>&lt;<% end %>
    <% end %>

    <%# Page number input with total pages (navigate on Enter) %>
    <form method="get" action="<%= request.path %>" class="flex items-center gap-1">
      <% base_params.each do |key, value| %>
        <input type="hidden" name="<%= key %>" value="<%= value %>">
      <% end %>
      <input type="number" name="page"
             value="<%= collection.current_page %>"
             min="1" max="<%= collection.total_pages %>"
             class="w-14 border rounded-lg px-2 py-2 text-sm text-center
                    focus:ring-2 focus:ring-slate-400 focus:outline-none appearance-none">
      <span class="text-sm text-gray-600"><%= t("pagination.suffix", total: collection.total_pages) %></span>
    </form>

    <%# Next page %>
    <% if collection.last_page? %>
      <span class="<%= btn_disabled %>">&gt;</span>
    <% else %>
      <%= link_to url_for(base_params.merge("page" => collection.current_page + 1)), class: btn_active do %>&gt;<% end %>
    <% end %>

    <%# Last page %>
    <% if collection.last_page? %>
      <span class="<%= btn_disabled %>">&gt;|</span>
    <% else %>
      <%= link_to url_for(base_params.merge("page" => collection.total_pages)), class: btn_active do %>&gt;|<% end %>
    <% end %>

  </div>
<% end %>
