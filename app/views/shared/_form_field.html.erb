<%# locals: (form:, attr:, field_label: nil, field_type: :text_field, field_options: {}, hide_label: false) %>
<%
  field_type = local_assigns.fetch(:field_type, :text_field)
  field_options = local_assigns.fetch(:field_options, {})
  error = form.object.errors[attr]&.first

  # Apply common style for date/time fields (prevents iOS jitter)
  is_date_or_time = %i[date_field time_field].include?(field_type)
  base_class = ApplicationHelper::INPUT_CLASS
  if is_date_or_time
    base_class = [base_class, ApplicationHelper::DATE_INPUT_CLASS].join(" ")
    field_options[:placeholder] ||= " "
  end

  input_class = [base_class, error.present? ? "border-red-500" : nil].compact.join(" ")
%>
<div>
  <% unless hide_label %>
    <%= form.label attr,
          (field_label || form.object.class.human_attribute_name(attr)),
          class: ApplicationHelper::LABEL_CLASS %>
  <% end %>
  <%= form.public_send(field_type, attr, **{ class: input_class }.merge(field_options)) %>
  <% if error.present? %>
    <p class="mt-1 text-sm text-red-600"><%= error %></p>
  <% end %>
</div>
