<div class="min-h-screen flex flex-col items-center justify-center
            bg-gradient-to-br from-blue-400 to-blue-600 px-4">

  <!-- アプリヘッダー -->
  <div class="text-center mb-6">
    <h1 class="text-3xl font-bold text-white/90">MyDiary</h1>
    <p class="text-white/90 mt-1">出費・日記管理アプリ</p>
  </div>

  <!-- カード -->
  <div class="w-full max-w-md bg-white p-6 rounded-2xl shadow-xl">

    <%= render "shared/flash" %>

    <h2 class="text-2xl font-bold text-center mb-6">新しいパスワードを設定</h2>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
      <%= f.hidden_field :reset_password_token %>

      <div class="mb-4">
        <%= f.label :password, "新しいパスワード", class: "block font-semibold mb-1" %>
        <% if @minimum_password_length %>
          <p class="text-xs text-gray-500 mb-1"><%= @minimum_password_length %>文字以上</p>
        <% end %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password",
              class: "w-full border rounded-lg p-3 focus:ring-2 focus:ring-blue-400 focus:outline-none#{resource.errors[:password].any? ? ' border-red-500' : ''}" %>
        <% if resource.errors[:password].any? %>
          <p class="mt-1 text-sm text-red-600"><%= resource.errors[:password].first %></p>
        <% end %>
      </div>

      <div class="mb-6">
        <%= f.label :password_confirmation, "新しいパスワード（確認）", class: "block font-semibold mb-1" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "w-full border rounded-lg p-3 focus:ring-2 focus:ring-blue-400 focus:outline-none#{resource.errors[:password_confirmation].any? ? ' border-red-500' : ''}" %>
        <% if resource.errors[:password_confirmation].any? %>
          <p class="mt-1 text-sm text-red-600"><%= resource.errors[:password_confirmation].first %></p>
        <% end %>
      </div>

      <%= f.submit "パスワードを変更する",
            class: "w-full bg-blue-600 text-white rounded-lg font-semibold hover:bg-blue-700 transition p-3" %>
    <% end %>

  </div>
</div>
