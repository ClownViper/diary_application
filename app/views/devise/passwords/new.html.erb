<div class="min-h-screen flex flex-col items-center justify-center
            bg-gradient-to-br from-slate-400 to-slate-600 px-4">

  <!-- App header -->
  <div class="text-center mb-6">
    <h1 class="text-3xl font-bold text-white/90"><%= app_name %></h1>
    <p class="text-white/90 mt-1"><%= app_subtitle %></p>
  </div>

  <!-- Card -->
  <div class="w-full max-w-md bg-white p-6 rounded-2xl shadow-xl">

    <%= render "shared/flash" %>

    <h2 class="text-2xl font-bold text-center mb-6"><%= t("devise.passwords.new.title") %></h2>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <div class="mb-4">
        <%= f.label :email, t("devise.passwords.new.email"), class: "block font-semibold mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full border rounded-lg p-3 focus:ring-2 focus:ring-slate-400 focus:outline-none#{resource.errors[:email].any? ? ' border-red-500' : ''}" %>
        <% if resource.errors[:email].any? %>
          <p class="mt-1 text-sm text-red-600"><%= resource.errors[:email].first %></p>
        <% end %>
      </div>

      <%= f.submit t("devise.passwords.new.submit"),
            class: "w-full bg-slate-600 text-white rounded-lg font-semibold hover:bg-slate-700 transition p-3" %>
    <% end %>

    <div class="mt-4 text-center">
      <%= link_to t("devise.passwords.new.back_to_login"), new_user_session_path,
            class: "text-slate-600 font-semibold hover:underline" %>
    </div>

    <!-- Locale switcher -->
    <div class="mt-4 pt-3 border-t flex justify-center">
      <%= render "shared/locale_switcher" %>
    </div>

  </div>
</div>
