<div class="min-h-screen flex flex-col items-center justify-center
            bg-gradient-to-br from-blue-400 to-blue-600 px-4">

  <!-- アプリヘッダー -->
  <div class="text-center mb-6">
    <h1 class="text-3xl font-bold text-white/90">MyDiary</h1>
    <p class="text-white/90 mt-1">出費・日記管理アプリ</p>
  </div>

  <!-- カード -->
  <div class="w-full max-w-md bg-white p-6 rounded-2xl shadow-xl">

    <%= render "shared/flash" %>

    <h2 class="text-2xl font-bold text-center mb-6">パスワードをお忘れの方</h2>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <div class="mb-4">
        <%= f.label :email, "メールアドレス", class: "block font-semibold mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full border rounded-lg p-3 focus:ring-2 focus:ring-blue-400 focus:outline-none#{resource.errors[:email].any? ? ' border-red-500' : ''}" %>
        <% if resource.errors[:email].any? %>
          <p class="mt-1 text-sm text-red-600"><%= resource.errors[:email].first %></p>
        <% end %>
      </div>

      <%= f.submit "パスワードリセットの手順を送信",
            class: "w-full bg-blue-600 text-white rounded-lg font-semibold hover:bg-blue-700 transition p-3" %>
    <% end %>

    <div class="mt-4 text-center">
      <%= link_to "ログインに戻る", new_user_session_path,
            class: "text-blue-600 font-semibold hover:underline" %>
    </div>

  </div>
</div>
