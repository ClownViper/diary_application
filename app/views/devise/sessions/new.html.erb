<div class="min-h-screen flex flex-col items-center justify-center
            bg-gradient-to-br from-slate-400 to-slate-600 px-4">

  <!-- App header -->
  <div class="text-center mb-6">
    <h1 class="text-3xl font-bold text-white/90"><%= app_name %></h1>
    <p class="text-white/90 mt-1"><%= app_subtitle %></p>
  </div>

  <!-- Login card -->
  <div class="w-full max-w-md bg-white p-6 rounded-2xl shadow-xl">

    <%= render "shared/flash" %>

    <h2 class="text-2xl font-bold text-center mb-2"><%= t("devise.sessions.new.title") %></h2>

    <%= form_with scope: :user, url: session_path(:user) do |f| %>

      <!-- Email field -->
      <div>
        <%= f.label :email, t("devise.sessions.new.email"), class: "block font-semibold mb-1" %>
        <%= f.email_field :email,
              autofocus: true,
              class: "w-full border rounded-lg p-3 focus:ring-2 focus:ring-slate-400 focus:outline-none" %>
      </div>

      <!-- Password field -->
      <div class="mt-6">
        <%= f.label :password, t("devise.sessions.new.password"), class: "block font-semibold mb-5" %>
        <%= f.password_field :password,
              autocomplete: "current-password",
              class: "w-full border rounded-lg p-3 focus:ring-2 focus:ring-slate-400 focus:outline-none" %>
      </div>

      <!-- Remember me -->
      <% if devise_mapping.rememberable? %>
        <div class="flex items-center mt-6">
          <%= f.check_box :remember_me, class: "mr-2" %>
          <%= f.label :remember_me, t("devise.sessions.new.remember_me") %>
        </div>
      <% end %>

      <!-- Submit button -->
      <%= f.submit t("devise.sessions.new.submit"),
            class: "w-full bg-clay-500 text-white rounded-lg font-semibold hover:bg-clay-600 transition mt-4 p-3" %>

    <% end %>

    <!-- Demo account info -->
    <div class="mt-4 bg-slate-50 border border-slate-200 rounded-lg p-3 text-sm text-gray-700">
      <p class="font-semibold mb-1"><%= t("devise.sessions.new.demo_title") %></p>
      <p><%= t("devise.sessions.new.email") %>: <code class="font-mono">test@example.com</code></p>
      <p><%= t("devise.sessions.new.password") %>: <code class="font-mono">password</code></p>
      <p class="text-xs text-gray-500 mt-1"><%= t("devise.sessions.new.demo_note") %></p>
    </div>

    <%# デモ公開用に新規登録リンクを無効化中（routes.rb の skip: [:registrations] とセットで if false を外して戻す） %>
    <% if false %>
      <div class="mt-3 text-center">
        <p class="text-gray-600">
          <%= t("devise.sessions.new.no_account") %>
          <%= link_to t("devise.sessions.new.sign_up_link"), new_user_registration_path,
                class: "text-slate-600 font-semibold hover:underline" %>
        </p>
      </div>
    <% end %>

    <!-- Locale switcher -->
    <div class="mt-4 pt-3 border-t flex justify-center">
      <%= render "shared/locale_switcher" %>
    </div>

  </div>
</div>
