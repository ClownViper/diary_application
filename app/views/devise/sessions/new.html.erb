<div class="min-h-screen flex flex-col items-center justify-center
            bg-gradient-to-br from-slate-400 to-slate-600 px-4">

  <!-- アプリヘッダー -->
  <div class="text-center mb-6">
    <h1 class="text-3xl font-bold text-white/90"><%= app_name %></h1>
    <p class="text-white/90 mt-1"><%= app_subtitle %></p>
  </div>

  <!-- ログインカード -->
  <div class="w-full max-w-md bg-white p-6 rounded-2xl shadow-xl">

    <%= render "shared/flash" %>

    <h2 class="text-2xl font-bold text-center mb-2">ログイン</h2>

    <%= form_with scope: :user, url: session_path(:user) do |f| %>

      <!-- メールアドレス -->
      <div>
        <%= f.label :email, "メールアドレス", class: "block font-semibold mb-1" %>
        <%= f.email_field :email,
              autofocus: true,
              class: "w-full border rounded-lg p-3 focus:ring-2 focus:ring-slate-400 focus:outline-none" %>
      </div>

      <!-- パスワード -->
      <div class="mt-6">
        <%= f.label :password, "パスワード", class: "block font-semibold mb-5" %>
        <%= f.password_field :password,
              autocomplete: "current-password",
              class: "w-full border rounded-lg p-3 focus:ring-2 focus:ring-slate-400 focus:outline-none" %>
      </div>

      <!-- ログイン状態保持 -->
      <% if devise_mapping.rememberable? %>
        <div class="flex items-center mt-6">
          <%= f.check_box :remember_me, class: "mr-2" %>
          <%= f.label :remember_me, "ログイン状態を保持する" %>
        </div>
      <% end %>

      <!-- ボタン -->
      <%= f.submit "ログイン",
            class: "w-full bg-slate-600 text-white rounded-lg font-semibold hover:bg-slate-700 transition mt-4 p-3" %>

    <% end %>

    <!-- 新規登録リンク -->
    <div class="mt-3 text-center">
      <p class="text-gray-600">
        アカウントをお持ちでない方は
        <%= link_to "新規登録", new_user_registration_path,
              class: "text-slate-600 font-semibold hover:underline" %>
      </p>
    </div>

  </div>
</div>
