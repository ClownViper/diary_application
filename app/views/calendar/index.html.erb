<div class="max-w-4xl mx-auto pb-8 mb-10">
  <%= render "shared/flash" %>

  <!-- Month navigation -->
  <div class="flex justify-between items-center mb-2 bg-slate-700 text-white p-2.5 rounded-lg">

    <!-- Left: previous month -->
    <%= link_to "◀︎", calendar_path(date: @date.prev_month),
          class: "text-lg font-bold px-3 py-1 hover:text-gray-200" %>

    <!-- Center: year/month + back to today -->
    <div class="flex items-center space-x-3">
      <h2 class="text-xl font-semibold"><%= l(@date, format: :year_month) %></h2>

      <% unless @date.month == Date.today.month && @date.year == Date.today.year %>
        <%= link_to t("shared.today_link"), calendar_path(date: Date.today),
              class: "text-sm underline hover:text-gray-200" %>
      <% end %>
    </div>

    <!-- Right: next month -->
    <%= link_to "▶︎", calendar_path(date: @date.next_month),
          class: "text-lg font-bold px-3 py-1 hover:text-gray-200" %>

  </div>

  <%# Legend (only features enabled in content settings) %>
  <div class="flex gap-4 mb-2 text-xs text-gray-600">
    <% if current_user.feature_diary %>
      <span><span class="text-indigo-500">●</span> <%= t("calendar.index.legend.diary") %></span>
    <% end %>
    <% if current_user.feature_expense %>
      <span><span class="text-emerald-500">▲</span> <%= t("calendar.index.legend.expense") %></span>
    <% end %>
    <% if current_user.feature_health_log %>
      <span><span class="text-rose-500">◆</span> <%= t("calendar.index.legend.health") %></span>
    <% end %>
    <% if current_user.feature_schedule %>
      <span><span class="text-amber-500">★</span> <%= t("calendar.index.legend.schedule") %></span>
    <% end %>
  </div>

  <!-- Desktop only: 7-column calendar grid -->
  <div class="hidden md:block">

    <!-- Weekday header row -->
    <div class="grid grid-cols-7 text-center font-semibold mb-1">
      <% t("date.abbr_day_names").each_with_index do |name, i| %>
        <div class="<%= i == 0 ? 'text-red-500' : i == 6 ? 'text-blue-500' : '' %>"><%= name %></div>
      <% end %>
    </div>

    <!-- Calendar body -->
    <div class="grid grid-cols-7 gap-1">

      <%# Blank cells for day-of-week offset (Sun=0, Mon=1, ...) %>
      <% first_wday = @start_date.wday %>
      <% first_wday.times do %>
        <div class="bg-transparent"></div>
      <% end %>

      <% @start_date.upto(@end_date) do |day| %>
        <% diary = @diaries_by_date[day] %>
        <% expenses = @expenses_by_date[day] %>
        <% health_log = @health_logs_by_date[day] %>
        <% schedules = @schedules_by_date[day] %>
        <% pc_day_color = case day.wday
                          when 0 then "text-red-500"
                          when 6 then "text-blue-500"
                          else ""
                          end %>

        <div
          class="bg-white border rounded-lg p-2 h-24 cursor-pointer hover:shadow-md transition flex flex-col"
          onclick="openCalendarLayer('<%= day %>')"
        >
          <div class="w-7 h-7 flex items-center justify-center rounded-full text-sm font-semibold
                      <%= day == Date.today ? 'bg-slate-500 text-white' : pc_day_color %>">
            <%= day.day %>
          </div>

          <%# Desktop: symbol badges (enabled features only) %>
          <div class="mt-1 flex flex-wrap gap-1 text-sm">
            <%= render "shared/calendar_badges", diary: diary, expenses: expenses, health_log: health_log, schedules: schedules %>
          </div>
        </div>
      <% end %>
    </div>

  </div>

  <!-- Mobile only: vertical day list -->
  <div class="md:hidden space-y-2">

    <% @start_date.upto(@end_date) do |day| %>
      <% diary = @diaries_by_date[day] %>
      <% expenses = @expenses_by_date[day] %>
      <% health_log = @health_logs_by_date[day] %>
      <% schedules = @schedules_by_date[day] %>

      <div
        class="bg-white border rounded-lg p-3 grid grid-cols-4 gap-2 hover:shadow transition"
        onclick="openCalendarLayer('<%= day %>')"
      >

        <!-- Left: date and weekday (1/4 width) -->
        <div class="col-span-1 flex items-center gap-2">

          <%# Weekday color class %>
          <% wday_color =
              case day.wday
              when 0 then "text-red-500"
              when 6 then "text-blue-500"
              else "text-gray-500"
              end
          %>

          <!-- Weekday label: fixed width keeps day numbers vertically aligned -->
          <div class="w-6 text-center text-xs flex-shrink-0 <%= wday_color %>">
            <%= t("date.abbr_day_names")[day.wday] %>
          </div>

          <!-- Day number (circled if today) -->
          <div class="w-8 h-8 flex items-center justify-center rounded-full text-lg font-bold flex-shrink-0
                      <%= day == Date.today ? 'bg-slate-500 text-white' : wday_color %>">
            <%= day.day %>
          </div>

        </div>

        <%# Mobile: symbol badges (enabled features only) %>
        <div class="col-span-3 flex items-center gap-2 text-lg">
          <%= render "shared/calendar_badges", diary: diary, expenses: expenses, health_log: health_log, schedules: schedules %>
        </div>

      </div>
    <% end %>

  </div>

</div>
