<div class="mb-4">
  <h2 class="text-xl font-bold"><%= l(@date, format: :full_date) %></h2>
</div>

<div class="space-y-4">

  <%# Diary section (controlled by content settings) %>
  <% if current_user.feature_diary %>
    <div>
      <div class="flex items-center justify-between bg-indigo-600 text-white px-3 py-2 rounded-t-lg">
        <div class="flex items-center gap-2">
          <span class="text-indigo-200">●</span>
          <span class="font-semibold"><%= t("calendar.layer.diary.title") %></span>
        </div>
        <% unless @diary.present? %>
          <%= link_to t("calendar.layer.diary.add"), new_diary_path(date: @date), class: "text-white text-sm" %>
        <% end %>
      </div>

      <div class="bg-white border border-indigo-200 rounded-b-lg p-0">
        <% if @diary.present? %>
          <%= link_to diary_path(@diary), class: "block p-4 hover:bg-indigo-50 transition rounded-b-lg" do %>
            <div class="flex gap-4">
              <%= render "shared/thumbnail", attachment: @diary.image %>
              <div class="flex flex-col min-w-0">
                <p class="font-semibold text-gray-800 text-lg truncate"><%= @diary.title %></p>
                <p class="text-sm text-gray-500"><%= format_date(@diary.date) %></p>
                <p class="text-gray-700 text-sm mt-1 line-clamp-3"><%= @diary.body %></p>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="p-4">
            <p class="text-gray-600 text-sm"><%= t("calendar.layer.diary.empty") %></p>
          </div>
        <% end %>
      </div>
    </div>

    <hr>
  <% end %>

  <%# Expenses section (controlled by content settings) %>
  <% if current_user.feature_expense %>
    <div>
      <div class="flex items-center justify-between bg-emerald-600 text-white px-3 py-2 rounded-t-lg">
        <div class="flex items-center gap-2">
          <span class="text-emerald-200">▲</span>
          <span class="font-semibold"><%= t("calendar.layer.expense.title") %></span>
        </div>
        <%= link_to t("calendar.layer.expense.add"), new_expense_path(date: @date), class: "text-white text-sm" %>
      </div>

      <%# Shows first item; displays "see all" link when there are multiple %>
      <div class="bg-white border border-emerald-300 rounded-b-lg p-4 space-y-3">
        <% if @expenses.any? %>
          <% first_expense = @expenses.first %>
          <%= link_to expense_path(first_expense),
                class: "block border rounded-lg p-3 shadow-sm bg-emerald-50 hover:bg-emerald-100 transition" do %>
            <div class="flex justify-between text-sm font-semibold">
              <span><%= first_expense.name.presence || t("calendar.layer.expense.no_title") %></span>
              <span><%= number_to_currency(first_expense.amount, unit: "¥") %></span>
            </div>
            <div class="text-xs text-gray-600 mt-1">
              <%= first_expense.category&.name.presence || t("shared.uncategorized") %>
            </div>
          <% end %>

          <div class="flex justify-between items-center mt-2">
            <% if @expenses.size > 1 %>
              <%= link_to t("calendar.layer.expense.all_items", count: @expenses.size), expenses_path(date: @date), class: "text-emerald-600 underline text-sm" %>
            <% else %>
              <span></span>
            <% end %>
            <div class="text-right font-bold text-lg">
              <%= t("calendar.layer.expense.total", amount: number_to_currency(@expenses.sum(&:amount), unit: "¥")) %>
            </div>
          </div>
        <% else %>
          <p class="text-gray-600 text-sm"><%= t("calendar.layer.expense.empty") %></p>
        <% end %>
      </div>
    </div>

    <hr>
  <% end %>

  <%# Health log section (controlled by content settings) %>
  <% if current_user.feature_health_log %>
    <div>
      <div class="flex items-center justify-between bg-rose-600 text-white px-3 py-2 rounded-t-lg">
        <div class="flex items-center gap-2">
          <span class="text-rose-200">◆</span>
          <span class="font-semibold"><%= t("calendar.layer.health_log.title") %></span>
        </div>
        <% unless @health_log.present? %>
          <%= link_to t("calendar.layer.health_log.add"), new_health_log_path(date: @date), class: "text-white text-sm" %>
        <% end %>
      </div>

      <div class="bg-white border border-rose-200 rounded-b-lg p-4">
        <% if @health_log.present? %>
          <%= link_to health_log_path(@health_log), class: "block hover:bg-rose-50 transition rounded-lg p-2" do %>
            <div class="flex gap-6 text-sm">
              <% if @health_log.weight.present? %>
                <div>
                  <span class="text-gray-500"><%= t("calendar.layer.health_log.weight") %></span>
                  <span class="font-semibold"><%= @health_log.weight %> kg</span>
                </div>
              <% end %>
              <% if @health_log.condition.present? %>
                <div>
                  <span class="text-gray-500"><%= t("calendar.layer.health_log.condition") %></span>
                  <span class="font-semibold"><%= @health_log.condition_label %></span>
                </div>
              <% end %>
            </div>
            <% if @health_log.memo.present? %>
              <p class="text-xs text-gray-500 mt-1"><%= @health_log.memo.truncate(30) %></p>
            <% end %>
          <% end %>
        <% else %>
          <p class="text-gray-600 text-sm"><%= t("calendar.layer.health_log.empty") %></p>
        <% end %>
      </div>
    </div>

    <hr>
  <% end %>

  <%# Schedule section (controlled by content settings) %>
  <% if current_user.feature_schedule %>
    <div>
      <div class="flex items-center justify-between bg-amber-500 text-white px-3 py-2 rounded-t-lg">
        <div class="flex items-center gap-2">
          <span class="text-amber-200">★</span>
          <span class="font-semibold"><%= t("calendar.layer.schedule.title") %></span>
        </div>
        <%= link_to t("calendar.layer.schedule.add"), new_schedule_path(date: @date), class: "text-white text-sm" %>
      </div>

      <%# Shows first item; displays "see all" link when there are multiple %>
      <div class="bg-white border border-amber-200 rounded-b-lg p-4 space-y-2">
        <% if @schedules.any? %>
          <% first_schedule = @schedules.first %>
          <%= link_to schedule_path(first_schedule),
                class: "block border rounded-lg p-3 shadow-sm bg-amber-50 hover:bg-amber-100 transition" do %>
            <div class="flex justify-between text-sm">
              <span class="font-semibold"><%= first_schedule.title %></span>
              <% if first_schedule.start_time.present? %>
                <span class="text-gray-600">
                  <%= first_schedule.start_time.strftime("%H:%M") %>
                  <% if first_schedule.end_time.present? %>
                    〜 <%= first_schedule.end_time.strftime("%H:%M") %>
                  <% end %>
                </span>
              <% end %>
            </div>
          <% end %>

          <% if @schedules.size > 1 %>
            <%= link_to t("calendar.layer.schedule.all_items", count: @schedules.size), schedules_path(date: @date), class: "text-amber-600 underline text-sm" %>
          <% end %>
        <% else %>
          <p class="text-gray-600 text-sm"><%= t("calendar.layer.schedule.empty") %></p>
        <% end %>
      </div>
    </div>
  <% end %>

</div>
