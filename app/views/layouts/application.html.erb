<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <title><%= content_for(:title) || app_name %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= app_name %>">
    <meta name="mobile-web-app-capable" content="yes">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <% if user_signed_in? && Rails.application.credentials.dig(:webpush, :public_key).present? %>
      <meta name="vapid-public-key" content="<%= Rails.application.credentials.dig(:webpush, :public_key) %>">
    <% end %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#334155">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
      body { font-family: 'Noto Sans JP', sans-serif; }
    </style>

    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100" data-turbo="false">

    <% if user_signed_in? %>
      <!-- PC Sidebar -->
      <aside class="hidden md:flex flex-col w-64 h-screen fixed left-0 top-0
                    bg-slate-700 text-white p-6 shadow-lg">

        <h1 class="text-2xl font-bold text-white mb-6"><%= app_name %></h1>

        <nav>
          <%= render "shared/sidebar_nav" %>
        </nav>

        <div class="mt-auto border-t border-slate-500 pt-4">
          <p class="text-sm text-white px-3 mb-1">
            <%= current_user.name %>
          </p>

          <%= button_to t("layouts.logout"),
                destroy_user_session_path,
                method: :delete,
                form: { class: "inline" },
                class: "block w-full text-left px-3 py-2 text-sm rounded transition
                  hover:bg-slate-500 hover:text-white text-white" %>
        </div>
      </aside>

      <!-- Mobile Header -->
      <header class="md:hidden fixed top-0 left-0 right-0 bg-slate-700 text-white shadow p-4 flex justify-between items-center z-50">
        <h1 class="text-xl font-bold"><%= app_name %></h1>
        <button id="menuButton" class="text-3xl">☰</button>
      </header>

      <!-- Mobile Slide Menu -->
      <div id="mobileMenu"
           class="md:hidden fixed top-0 left-0 w-64 h-full bg-slate-700 text-white shadow-lg p-6
                  transform -translate-x-full transition-transform z-40">

        <nav class="space-y-2 mt-10 mb-10">
          <%= render "shared/sidebar_nav" %>
        </nav>

        <div class="mt-auto border-t border-slate-500 pt-4">
          <p class="text-sm text-white px-3 mb-1">
            <%= current_user.email %>
          </p>

          <%= button_to t("layouts.logout"),
              destroy_user_session_path,
              method: :delete,
              form: { class: "w-full" },
              class: "block w-full text-left px-3 py-2 text-sm rounded transition
                hover:bg-slate-500 hover:text-white text-white" %>
        </div>
      </div>
    <% end %>

    <!-- Main Content -->
    <main class="
      mx-auto
      <%= user_signed_in? ? 'pt-20 max-w-screen-xl px-5 md:ml-64 md:pt-10' : 'md:ml-0 md:pt-0' %>
    ">
      <%= yield %>
    </main>

    <!-- Mobile Menu Script -->
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const btn = document.getElementById("menuButton");
        const menu = document.getElementById("mobileMenu");

        if (btn) {
          btn.onclick = () => {
            menu.classList.toggle("-translate-x-full");
          };
        }
      });

      // Toggle settings submenu open/close
      function toggleSettingsMenu(button) {
        const submenu = button.nextElementSibling;
        const arrow = button.querySelector(".settings-arrow");
        submenu.classList.toggle("hidden");
        arrow.style.transform = submenu.classList.contains("hidden") ? "" : "rotate(180deg)";
      }
    </script>

    <!-- Calendar Layer -->
    <div id="calendarLayer"
         class="fixed top-0 left-0 w-screen h-screen bg-black/50 hidden items-center justify-center z-[99999]">
      <%# Layer height capped at 80vh with scroll support %>
      <div id="calendarLayerContent"
           class="bg-white w-[90%] max-w-[600px] max-h-[80vh] overflow-y-auto p-6 rounded-xl relative">
        <button onclick="closeCalendarLayer()"
                class="absolute top-3 right-3 w-10 h-10 flex items-center justify-center
                    text-2xl font-bold text-gray-600 hover:text-black
                    rounded-full hover:bg-gray-200 transition">×</button>
        <div id="calendarLayerBody"></div>
      </div>
    </div>
    <!-- Book Scanner Layer -->
    <% if user_signed_in? %>
    <div id="bookScannerLayer"
         class="fixed top-0 left-0 w-screen h-screen bg-black/50 hidden items-center justify-center z-[99999]">
      <div class="bg-white w-[92%] max-w-md max-h-[85vh] overflow-y-auto p-6 rounded-xl relative">
        <button type="button" onclick="closeBookScanner()"
                class="absolute top-3 right-3 w-10 h-10 flex items-center justify-center
                       text-2xl font-bold text-gray-600 hover:text-black rounded-full hover:bg-gray-200 transition">×</button>

        <h3 class="text-lg font-bold text-gray-800 mb-1 pr-10"><%= t("books.scanner.modal_title") %></h3>
        <p class="text-xs text-gray-400 mb-4"><%= t("books.scanner.isbn_hint") %></p>

        <%# Camera preview area %>
        <div id="bookScannerReader" class="mb-3 rounded-lg overflow-hidden bg-gray-100 min-h-[10px]"></div>

        <%# Status message %>
        <div id="bookScannerStatus" class="text-sm text-gray-500 mb-3 text-center hidden"></div>

        <%# Result card %>
        <div id="bookScannerResult" class="hidden mb-4 p-3 border rounded-lg bg-gray-50 flex gap-3 items-start">
          <img id="bookScannerThumb" src="" alt="" class="w-14 h-20 object-cover rounded hidden flex-shrink-0">
          <div class="min-w-0">
            <p id="bookScannerTitle" class="font-semibold text-gray-800 text-sm"></p>
            <p id="bookScannerAuthor" class="text-xs text-gray-500 mt-1"></p>
          </div>
        </div>

        <%# Manual ISBN input %>
        <div class="flex gap-2 mb-4">
          <input id="bookIsbnInput" type="text" inputmode="numeric"
                 placeholder="<%= t("books.scanner.isbn_placeholder") %>"
                 class="flex-1 border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-300"
                 onkeydown="if(event.key==='Enter'){bookScannerSearchManual();}">
          <button type="button" onclick="bookScannerSearchManual()"
                  class="px-4 py-2 bg-slate-600 text-white text-sm rounded-lg hover:bg-slate-700 transition whitespace-nowrap">
            <%= t("books.scanner.search_button") %>
          </button>
        </div>

        <%# Action buttons %>
        <div class="flex justify-end items-center">
          <button type="button" id="bookScannerRetryBtn" onclick="bookScannerRetry()"
                  class="text-sm text-slate-600 underline hidden mr-auto">
            <%= t("books.scanner.retry") %>
          </button>
          <button type="button" id="bookScannerFillBtn" onclick="bookScannerFill()"
                  class="hidden px-4 py-2 bg-slate-600 text-white text-sm rounded-lg hover:bg-slate-700 transition whitespace-nowrap">
            <%= t("books.scanner.fill_button") %>
          </button>
        </div>
      </div>
    </div>

    <script>
      (function () {
        let _scanner = null;
        let _lastResult = null;
        const SEARCH_URL = "<%= search_isbn_books_path %>";
        const MSG = {
          scanning:    "<%= j t('books.scanner.scanning') %>",
          cameraError: "<%= j t('books.scanner.camera_error') %>",
          searching:   "<%= j t('books.scanner.searching') %>",
          notFound:    "<%= j t('books.scanner.not_found') %>",
          apiError:    "<%= j t('books.scanner.api_error') %>",
        };

        function loadLib(cb) {
          if (window.Html5Qrcode) { cb(); return; }
          const s = document.createElement("script");
          s.src = "https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js";
          s.onload = cb;
          document.head.appendChild(s);
        }

        function setStatus(msg) {
          const el = document.getElementById("bookScannerStatus");
          el.textContent = msg;
          el.classList.toggle("hidden", !msg);
        }

        function startCamera() {
          setStatus(MSG.scanning);
          _scanner = new Html5Qrcode("bookScannerReader");
          _scanner.start(
            { facingMode: "environment" },
            { fps: 10, qrbox: { width: 240, height: 100 } },
            (decoded) => { stopCamera(); lookup(decoded); },
            () => {}
          ).catch(() => {
            _scanner = null;
            setStatus(MSG.cameraError);
          });
        }

        function stopCamera() {
          if (_scanner) {
            const s = _scanner;
            _scanner = null;
            try { s.stop().catch(() => {}); } catch { /* not running */ }
          }
        }

        async function lookup(isbn) {
          isbn = isbn.replace(/[^0-9X]/gi, "");
          if (isbn.length < 10) { setStatus(MSG.notFound); return; }
          setStatus(MSG.searching);
          document.getElementById("bookScannerResult").classList.add("hidden");
          document.getElementById("bookScannerFillBtn").classList.add("hidden");
          document.getElementById("bookScannerRetryBtn").classList.add("hidden");
          try {
            const res = await fetch(`${SEARCH_URL}?isbn=${isbn}`, {
              headers: { "Accept": "application/json", "X-Requested-With": "XMLHttpRequest" }
            });
            const data = await res.json();
            if (res.ok) {
              _lastResult = data;
              setStatus("");
              document.getElementById("bookScannerTitle").textContent  = data.title  || "";
              document.getElementById("bookScannerAuthor").textContent = data.author || "";
              const thumb = document.getElementById("bookScannerThumb");
              if (data.thumbnail) { thumb.src = data.thumbnail; thumb.classList.remove("hidden"); }
              else { thumb.classList.add("hidden"); }
              document.getElementById("bookScannerResult").classList.remove("hidden");
              document.getElementById("bookScannerFillBtn").classList.remove("hidden");
              document.getElementById("bookScannerRetryBtn").classList.remove("hidden");
            } else {
              setStatus(data.error || MSG.notFound);
              document.getElementById("bookScannerRetryBtn").classList.remove("hidden");
            }
          } catch {
            setStatus(MSG.apiError);
            document.getElementById("bookScannerRetryBtn").classList.remove("hidden");
          }
        }

        // Global functions (called from onclick)
        window.openBookScanner = function () {
          _lastResult = null;
          document.getElementById("bookScannerResult").classList.add("hidden");
          document.getElementById("bookScannerFillBtn").classList.add("hidden");
          document.getElementById("bookScannerRetryBtn").classList.add("hidden");
          document.getElementById("bookIsbnInput").value = "";
          setStatus("");
          const layer = document.getElementById("bookScannerLayer");
          layer.classList.remove("hidden");
          layer.classList.add("flex");
          loadLib(startCamera);
        };

        window.closeBookScanner = function () {
          stopCamera();
          const layer = document.getElementById("bookScannerLayer");
          layer.classList.add("hidden");
          layer.classList.remove("flex");
        };

        window.bookScannerFill = function () {
          if (!_lastResult) return;
          const t = document.getElementById("book_title");
          const a = document.getElementById("book_author");
          if (t) t.value = _lastResult.title  || "";
          if (a) a.value = _lastResult.author || "";
          window.closeBookScanner();
        };

        window.bookScannerRetry = function () {
          document.getElementById("bookScannerResult").classList.add("hidden");
          document.getElementById("bookScannerFillBtn").classList.add("hidden");
          document.getElementById("bookScannerRetryBtn").classList.add("hidden");
          startCamera();
        };

        window.bookScannerSearchManual = function () {
          const isbn = document.getElementById("bookIsbnInput").value.trim();
          if (isbn) lookup(isbn);
        };
      })();
    </script>
    <% end %>

    <script>
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.register("/service_worker.js");
      }
    </script>
  </body>
</html>
