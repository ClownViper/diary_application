<!DOCTYPE html>
<html lang="<%= bcp47_locale %>">
  <head>
    <meta charset="utf-8">
    <title><%= content_for(:title) || app_name %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= app_name %>">
    <meta name="mobile-web-app-capable" content="yes">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <% if user_signed_in? && Rails.application.credentials.dig(:webpush, :public_key).present? %>
      <meta name="vapid-public-key" content="<%= Rails.application.credentials.dig(:webpush, :public_key) %>">
    <% end %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#4c3424">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;500;700&family=Zen+Maru+Gothic:wght@500;700&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "application" %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
      body { font-family: 'Zen Kaku Gothic New', 'Noto Sans JP', sans-serif; }
      /* Friendly rounded headings for a warmer, diary-like feel */
      h1, h2 { font-family: 'Zen Maru Gothic', 'Zen Kaku Gothic New', sans-serif; }
      .flatpickr-input[readonly] { cursor: pointer; }
    </style>

    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100" data-turbo="false">

    <% if user_signed_in? %>
      <!-- PC Sidebar -->
      <aside class="hidden md:flex flex-col w-64 h-screen fixed left-0 top-0
                    bg-slate-700 text-white p-6 shadow-lg">

        <h1 class="text-2xl font-bold text-white mb-6"><%= app_name %></h1>

        <nav>
          <%= render "shared/sidebar_nav" %>
        </nav>

        <div class="mt-auto border-t border-slate-500 pt-4">
          <p class="text-sm text-white px-3 mb-1">
            <%= current_user.display_name %>
          </p>

          <%= button_to t("layouts.logout"),
                destroy_user_session_path,
                method: :delete,
                form: { class: "inline" },
                class: "block w-full text-left px-3 py-2 text-sm rounded transition
                  hover:bg-slate-500 hover:text-white text-white" %>
        </div>
      </aside>

      <!-- Mobile Header -->
      <header class="md:hidden fixed top-0 left-0 right-0 bg-slate-700 text-white shadow p-4 flex justify-between items-center z-50">
        <h1 class="text-xl font-bold"><%= app_name %></h1>
        <button id="menuButton" class="text-3xl">☰</button>
      </header>

      <!-- Mobile Slide Menu -->
      <div id="mobileMenu"
           class="md:hidden flex flex-col fixed top-0 left-0 w-64 h-full bg-slate-700 text-white shadow-lg p-6
                  transform -translate-x-full transition-transform z-40">

        <nav class="space-y-2 mt-10 mb-10">
          <%= render "shared/sidebar_nav" %>
        </nav>

        <div class="mt-auto border-t border-slate-500 pt-4">
          <p class="text-sm text-white px-3 mb-1">
            <%= current_user.display_name %>
          </p>

          <%= button_to t("layouts.logout"),
              destroy_user_session_path,
              method: :delete,
              form: { class: "w-full" },
              class: "block w-full text-left px-3 py-2 text-sm rounded transition
                hover:bg-slate-500 hover:text-white text-white" %>
        </div>
      </div>
    <% end %>

    <!-- Main Content -->
    <main class="
      mx-auto
      <%= user_signed_in? ? 'pt-20 max-w-screen-xl px-5 md:ml-64 md:pt-10' : 'md:ml-0 md:pt-0' %>
    ">
      <%= yield %>
    </main>

    <!-- Calendar Layer -->
    <div id="calendarLayer"
         class="fixed top-0 left-0 w-screen h-screen bg-black/50 hidden items-center justify-center z-[99999]">
      <%# Layer height capped at 80vh with scroll support %>
      <div id="calendarLayerContent"
           class="bg-white w-[90%] max-w-[600px] max-h-[80vh] overflow-y-auto p-6 rounded-xl relative">
        <button onclick="closeCalendarLayer()"
                class="absolute top-3 right-3 w-10 h-10 flex items-center justify-center
                    text-2xl font-bold text-gray-600 hover:text-black
                    rounded-full hover:bg-gray-200 transition">×</button>
        <div id="calendarLayerBody"></div>
      </div>
    </div>

    <!-- Global loading overlay (shown during form submits; see form_submit.js) -->
    <div id="loadingOverlay"
         data-default-text="<%= t('shared.saving') %>"
         data-nav-text="<%= t('shared.loading') %>"
         class="fixed inset-0 hidden items-center justify-center bg-black/30 z-[100000]">
      <div class="flex flex-col items-center gap-3 bg-white px-8 py-6 rounded-2xl shadow-xl">
        <span class="w-10 h-10 rounded-full border-4 border-gray-200 border-t-slate-700 animate-spin"></span>
        <span id="loadingOverlayText" class="text-sm font-medium text-gray-700"><%= t("shared.saving") %></span>
      </div>
    </div>
  </body>
</html>
