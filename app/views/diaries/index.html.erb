<div class="max-w-4xl mx-auto pb-8 mb-10">

  <%= render "shared/page_header", title: t("diaries.index.title"), button_label: t("shared.new_record"), button_path: new_diary_path(date: @date) %>

  <!-- Search form -->
  <div class="mb-6 bg-white p-4 rounded-xl border shadow-sm">
    <%= form_with url: diaries_path, method: :get, local: true, class: "grid grid-cols-1 md:grid-cols-3 gap-4" do |f| %>

      <div>
        <label class="<%= ApplicationHelper::SEARCH_LABEL_CLASS %>"><%= t("shared.search_form.keyword") %></label>
        <%= f.text_field :q, value: params[:q],
              placeholder: t("diaries.index.search_keyword_placeholder"),
              class: ApplicationHelper::INPUT_CLASS %>
      </div>

      <div>
        <label class="<%= ApplicationHelper::SEARCH_LABEL_CLASS %>"><%= t("shared.search_form.date") %></label>
        <%= f.date_field :date,
              placeholder: " ",
              class: [ApplicationHelper::INPUT_CLASS, "h-[42px] bg-white text-gray-800 appearance-none"].join(" ") %>
      </div>

      <div class="flex items-end">
        <%= f.submit t("shared.search"), class: [ui_button_classes(variant: :primary, size: :md), "w-full"].join(" ") %>
      </div>

    <% end %>
  </div>

  <!-- List cards -->
  <div class="w-full grid grid-cols-1 md:grid-cols-2 gap-6">

    <% @diaries.each do |diary| %>
      <%= link_to diary_path(diary),
            class: "block bg-white rounded-xl border shadow-sm hover:shadow-md transition p-4 flex gap-4" do %>

        <%= render "shared/thumbnail", attachment: diary.image %>

        <div class="flex flex-col min-w-0">
          <p class="font-semibold text-gray-800 text-lg truncate">
            <%= diary.title %>
          </p>

          <p class="text-sm text-gray-500">
            <%= format_date(diary.date) %>
          </p>

          <p class="text-gray-700 text-sm mt-1 line-clamp-2">
            <%= diary.body %>
          </p>
        </div>

      <% end %>
    <% end %>

  </div>

  <%= render "shared/empty_state", message: t("diaries.index.empty") if @diaries.empty? %>
  <%= render "shared/pagination", collection: @diaries %>
</div>
