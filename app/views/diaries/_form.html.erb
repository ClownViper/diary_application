<%= render layout: "shared/form_card" do %>
  <%= form_with model: diary, data: { turbo: false }, class: "space-y-6" do |f| %>

    <div class="!mt-2">
      <%= render "shared/form_field", form: f, attr: :title %>
    </div>

    <%= render "shared/form_field", form: f, attr: :date, field_type: :date_field %>

    <%= render "shared/form_field", form: f, attr: :body, field_type: :text_area,
          field_options: { rows: 8 } %>

    <%# File input UI with filename display %>
    <div>
      <%= f.label :image, t("diaries.form.image"), class: ApplicationHelper::LABEL_CLASS %>
      <div class="flex items-center gap-3">
        <label class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-300 rounded-lg cursor-pointer hover:bg-gray-50 transition text-sm text-gray-700 font-medium">
          <%= t("shared.file_select") %>
          <%= f.file_field :image, accept: "image/png,image/jpeg,image/webp", class: "hidden",
                onchange: "this.closest('div').querySelector('.file-name').textContent = this.files[0]?.name || ''" %>
        </label>
        <span class="file-name text-sm text-gray-500"></span>
      </div>
      <% if diary.image.attached? %>
        <div class="mt-2">
          <%= image_tag diary.image, class: "w-20 h-28 object-cover rounded" %>
        </div>
      <% end %>
      <% if diary.errors[:image].any? %>
        <p class="mt-1 text-sm text-red-600"><%= diary.errors[:image].first %></p>
      <% end %>
    </div>

    <div>
      <%= f.submit t("shared.save"), class: ui_button_classes(variant: :primary, size: :lg) %>
    </div>
  <% end %>
<% end %>
