<%= render layout: "shared/form_card" do %>
  <%= form_with model: diary, local: true, class: "space-y-6" do |f| %>
    <%= render "shared/form_errors", resource: diary %>

    <div class="!mt-2">
      <%= render "shared/form_field", form: f, attr: :title, field_label: "タイトル" %>
    </div>

    <%= render "shared/form_field", form: f, attr: :date, field_label: "日付", field_type: :date_field %>

    <%= render "shared/form_field", form: f, attr: :body, field_label: "本文", field_type: :text_area,
          field_options: { rows: 8 } %>

    <%# ファイル選択UI（読書ログと統一） %>
    <div>
      <%= f.label :image, "画像", class: ApplicationHelper::LABEL_CLASS %>
      <%= f.file_field :image, accept: "image/png,image/jpeg,image/webp",
            class: ApplicationHelper::FILE_INPUT_CLASS %>
      <% if diary.image.attached? %>
        <div class="mt-2">
          <%= image_tag diary.image, class: "w-20 h-28 object-cover rounded" %>
        </div>
      <% end %>
      <% if diary.errors[:image].any? %>
        <p class="mt-1 text-sm text-red-600"><%= diary.errors[:image].first %></p>
      <% end %>
    </div>

    <div>
      <%= f.submit "保存", class: ui_button_classes(variant: :primary, size: :lg) %>
    </div>
  <% end %>
<% end %>