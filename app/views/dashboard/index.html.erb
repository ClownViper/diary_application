<div class="max-w-4xl mx-auto pb-8 mb-10">
  <h1 class="text-2xl font-bold mb-6">ダッシュボード</h1>
  <%= render "shared/flash" %>

  <div class="w-full grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-2">

    <%# 今日の情報カード（日記・出費のいずれかがONの場合に表示） %>
    <% if current_user.feature_diary || current_user.feature_expense %>
      <div class="bg-white rounded-xl shadow-sm border p-6">
        <h2 class="text-lg font-bold text-gray-700 mb-4">
          今日の情報（<%= @today.strftime("%m/%d") %>）
        </h2>

        <div class="space-y-2">
          <% if current_user.feature_diary %>
            <% if @today_diary %>
              <p class="text-gray-700">
                📘 日記：
                <span class="font-bold text-lg"><%= @today_diary.title %></span>
              </p>
            <% else %>
              <p class="text-gray-700">📘 日記：なし</p>
            <% end %>
          <% end %>

          <% if current_user.feature_expense %>
            <p class="text-gray-700">
              💴 出費：
              <span class="font-bold text-lg"><%= number_with_delimiter(@today_expenses.sum(:amount)) %></span> 円
            </p>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# 今月の出費カード %>
    <% if current_user.feature_expense %>
      <div class="bg-white rounded-xl shadow-sm border p-6">
        <h2 class="text-lg font-bold text-gray-700 mb-4">今月の出費</h2>

        <p class="text-3xl font-extrabold text-gray-800 mb-2">
          <%= number_with_delimiter(@monthly_total) %> 円
        </p>

        <%# 出費目安金額に基づく進捗バー（コンテンツ設定で変更可能） %>
        <div class="w-full bg-gray-200 rounded-full h-3 mt-4">
          <div class="bg-red-400 h-3 rounded-full"
              style="width: <%= @expense_target > 0 ? [(@monthly_total / @expense_target.to_f * 100).round, 100].min : 0 %>%"></div>
        </div>

        <p class="text-sm text-gray-500 mt-1">※ 目安：<%= number_with_delimiter(@expense_target) %>円/月</p>
      </div>
    <% end %>

    <%# 今日の日記カード %>
    <% if current_user.feature_diary %>
      <div class="bg-white rounded-xl shadow-sm border p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-700">今日の日記</h2>

          <% if @today_diary %>
            <%= ui_link_button "編集", edit_diary_path(@today_diary), variant: :compact %>
          <% else %>
            <%= ui_link_button "追加", new_diary_path(date: @today), variant: :compact %>
          <% end %>
        </div>

        <% if @today_diary %>
          <p class="font-semibold text-gray-800"><%= @today_diary.title %></p>
          <p class="text-sm text-gray-500"><%= format_date(@today_diary.date) %></p>
          <p class="mt-2 text-gray-700 whitespace-pre-line"><%= @today_diary.body.truncate(80) %></p>
        <% else %>
          <p class="text-gray-500">日記はありません。</p>
        <% end %>
      </div>
    <% end %>

    <%# 今日の体調ログカード %>
    <% if current_user.feature_health_log %>
      <div class="bg-white rounded-xl shadow-sm border p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-700">今日の体調</h2>
          <div class="flex items-center gap-2">
            <%= ui_link_button "グラフ", stats_health_logs_path, variant: :compact %>
            <% if @today_health_log %>
              <%= ui_link_button "編集", edit_health_log_path(@today_health_log), variant: :compact %>
            <% else %>
              <%= ui_link_button "追加", new_health_log_path(date: @today), variant: :compact %>
            <% end %>
          </div>
        </div>

        <% if @today_health_log %>
          <div class="space-y-1 mb-4">
            <% if @today_health_log.weight.present? %>
              <p class="text-gray-700">体重: <span class="font-bold text-lg"><%= @today_health_log.weight %></span> kg</p>
            <% end %>
            <% if @today_health_log.condition.present? %>
              <p class="text-gray-700">体調: <span class="font-bold"><%= @today_health_log.condition_label %></span></p>
            <% end %>
          </div>
        <% else %>
          <p class="text-gray-500 mb-4">体調ログはありません。</p>
        <% end %>

        <!-- 体重スパークライン（直近30日） -->
        <% if @sparkline_any %>
          <div class="relative h-20">
            <canvas id="sparklineChart"></canvas>
          </div>
          <script>
            document.addEventListener("DOMContentLoaded", function () {
              new Chart(document.getElementById("sparklineChart").getContext("2d"), {
                type: "line",
                data: {
                  labels: <%= raw @sparkline_labels %>,
                  datasets: [{
                    data: <%= raw @sparkline_data %>,
                    borderColor: "rgb(59, 130, 246)",
                    backgroundColor: "rgba(59, 130, 246, 0.08)",
                    borderWidth: 1.5,
                    pointRadius: 2,
                    fill: true,
                    tension: 0.3
                  }]
                },
                options: {
                  responsive: true,
                  maintainAspectRatio: false,
                  plugins: { legend: { display: false }, tooltip: { callbacks: { label: c => `${c.parsed.y} kg` } } },
                  scales: {
                    x: { display: false },
                    y: { display: false }
                  }
                }
              });
            });
          </script>
          <p class="text-xs text-gray-400 text-right mt-1">直近30日の体重推移</p>
        <% end %>
      </div>
    <% end %>

    <%# 今日のスケジュールカード %>
    <% if current_user.feature_schedule %>
      <div class="bg-white rounded-xl shadow-sm border p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-700">今日の予定</h2>
          <%= ui_link_button "追加", new_schedule_path(date: @today), variant: :compact %>
        </div>

        <div class="space-y-2">
          <% if @today_schedules.any? %>
            <% @today_schedules.each do |schedule| %>
              <div class="border-b py-2 flex justify-between items-center">
                <span class="font-semibold text-gray-800"><%= schedule.title %></span>
                <% if schedule.start_time.present? %>
                  <span class="text-sm text-gray-500"><%= schedule.start_time.strftime("%H:%M") %></span>
                <% end %>
              </div>
            <% end %>
          <% else %>
            <p class="text-gray-500 text-sm">今日の予定はありません。</p>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# 読書中の本カード %>
    <% if current_user.feature_book %>
      <div class="bg-white rounded-xl shadow-sm border p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-700">読書中</h2>
          <%= ui_link_button "一覧", books_path, variant: :compact %>
        </div>

        <div class="space-y-2">
          <% if @reading_books.any? %>
            <% @reading_books.each do |book| %>
              <div class="border-b py-2">
                <p class="font-semibold text-gray-800"><%= book.title %></p>
                <p class="text-sm text-gray-500"><%= book.author.presence || "著者不明" %></p>
              </div>
            <% end %>
          <% else %>
            <p class="text-gray-500 text-sm">読書中の本はありません。</p>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- ミニカレンダー -->
    <div class="bg-white rounded-xl shadow-sm border p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-700"><%= @today.strftime("%-m月") %></h2>

        <%= ui_link_button "カレンダー", calendar_path, variant: :compact %>
      </div>

      <div class="grid grid-cols-7 text-center text-sm font-semibold text-gray-600 mb-2">
        <div class="text-red-500">日</div>
        <div>月</div>
        <div>火</div>
        <div>水</div>
        <div>木</div>
        <div>金</div>
        <div class="text-blue-500">土</div>
      </div>

      <div class="grid grid-cols-7 text-center gap-1">
        <% @first_day.wday.times do %>
          <div></div>
        <% end %>

        <% @days.each do |day| %>
          <% is_today = (day == @today) %>
          <% wday = day.wday %>

          <% text_color =
              case wday
              when 0 then "text-red-500"
              when 6 then "text-blue-500"
              else "text-gray-700"
              end
          %>

          <div class="flex items-center justify-center py-1">
            <div class="w-7 h-7 flex items-center justify-center rounded-full
                        <%= is_today ? 'bg-blue-500 text-white font-bold' : text_color %>">
              <%= day.day %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# 最近の出費カード %>
    <% if current_user.feature_expense %>
      <div class="bg-white rounded-xl shadow-sm border p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-700">最近の出費</h2>
          <%= ui_link_button "出費一覧", expenses_path, variant: :compact %>
        </div>

        <div class="space-y-3">
          <% if @recent_expenses.any? %>
            <% @recent_expenses.each do |e| %>
              <div class="border-b py-2 flex justify-between">
                <span><%= e.category&.name || "未分類" %></span>
                <span><%= e.amount %> 円</span>
              </div>
            <% end %>
          <% else %>
            <p class="text-gray-500 text-sm">最近の出費はありません。</p>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# 最近の日記カード %>
    <% if current_user.feature_diary %>
      <div class="bg-white rounded-xl shadow-sm border p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-700">最近の日記</h2>
          <%= ui_link_button "日記一覧", diaries_path, variant: :compact %>
        </div>

        <div class="space-y-3">
          <% if @recent_diaries.any? %>
            <% @recent_diaries.each do |d| %>
              <div class="border-b py-2">
                <p class="font-semibold"><%= d.title %></p>
                <p class="text-sm text-gray-600"><%= d.date %></p>
              </div>
            <% end %>
          <% else %>
            <p class="text-gray-500 text-sm">最近の日記はありません。</p>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
