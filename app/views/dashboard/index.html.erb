<div class="max-w-4xl mx-auto pb-8 mb-10">
  <h1 class="text-2xl font-bold mb-6"><%= t("dashboard.title") %></h1>
  <%= render "shared/flash" %>

  <%# Today at a glance: one hero card consolidating diary / expense / health / schedule %>
  <% today_features = [current_user.feature_diary, current_user.feature_expense,
                       current_user.feature_health_log, current_user.feature_schedule] %>
  <% if today_features.any? %>
    <section class="bg-white rounded-xl border shadow-sm p-6 mb-4">
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-lg font-bold text-gray-700">
          <%= t("dashboard.today_summary", date: @today.strftime("%m/%d")) %>
        </h2>
        <%= ui_link_button t("dashboard.mini_calendar_btn"), calendar_path, variant: :compact %>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-5">

        <% if current_user.feature_diary %>
          <div class="min-w-0">
            <p class="text-xs font-semibold text-gray-500 mb-1"><%= t("dashboard.cell_diary") %></p>
            <% if @today_diary %>
              <p class="font-bold text-gray-800 truncate"><%= @today_diary.title %></p>
              <%= link_to t("shared.edit"), edit_diary_path(@today_diary), class: "text-sm text-clay-600 hover:underline" %>
            <% else %>
              <p class="text-gray-400"><%= t("dashboard.cell_empty") %></p>
              <%= link_to t("dashboard.action_write"), new_diary_path(date: @today), class: "text-sm text-clay-600 hover:underline" %>
            <% end %>
          </div>
        <% end %>

        <% if current_user.feature_expense %>
          <div class="min-w-0">
            <p class="text-xs font-semibold text-gray-500 mb-1"><%= t("dashboard.cell_expense") %></p>
            <p class="font-bold text-gray-800">
              ¥<%= number_with_delimiter(@today_expenses.sum(:amount)) %>
            </p>
            <%= link_to t("dashboard.action_add"), new_expense_path, class: "text-sm text-clay-600 hover:underline" %>
          </div>
        <% end %>

        <% if current_user.feature_health_log %>
          <div class="min-w-0">
            <p class="text-xs font-semibold text-gray-500 mb-1"><%= t("dashboard.cell_health") %></p>
            <% if @today_health_log %>
              <p class="font-bold text-gray-800 truncate">
                <%= [(@today_health_log.weight.present? ? "#{@today_health_log.weight} kg" : nil),
                     @today_health_log.condition_label].compact.join(" / ") %>
              </p>
              <%= link_to t("shared.edit"), edit_health_log_path(@today_health_log), class: "text-sm text-clay-600 hover:underline" %>
            <% else %>
              <p class="text-gray-400"><%= t("dashboard.cell_empty") %></p>
              <%= link_to t("dashboard.action_record"), new_health_log_path(date: @today), class: "text-sm text-clay-600 hover:underline" %>
            <% end %>
          </div>
        <% end %>

        <% if current_user.feature_schedule %>
          <div class="min-w-0">
            <p class="text-xs font-semibold text-gray-500 mb-1"><%= t("dashboard.cell_schedule") %></p>
            <% if @today_schedules.any? %>
              <p class="font-bold text-gray-800 truncate">
                <%= @today_schedules.first.title %><% if @today_schedules.first.start_time.present? %>
                  <span class="text-sm font-normal text-gray-500"><%= @today_schedules.first.start_time.strftime("%H:%M") %></span>
                <% end %>
              </p>
              <% if @today_schedules.size > 1 %>
                <p class="text-xs text-gray-500"><%= t("dashboard.schedule_more", count: @today_schedules.size - 1) %></p>
              <% end %>
              <%= link_to t("schedules.index.title"), schedules_path, class: "text-sm text-clay-600 hover:underline" %>
            <% else %>
              <p class="text-gray-400"><%= t("dashboard.cell_none") %></p>
              <%= link_to t("dashboard.action_add"), new_schedule_path(date: @today), class: "text-sm text-clay-600 hover:underline" %>
            <% end %>
          </div>
        <% end %>

      </div>
    </section>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

    <%# Monthly expense card %>
    <% if current_user.feature_expense %>
      <div class="bg-white rounded-xl border shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-700"><%= t("dashboard.monthly_expense") %></h2>
          <%= ui_link_button t("expenses.index.title"), expenses_path, variant: :compact %>
        </div>

        <p class="text-3xl font-extrabold text-gray-800 mb-2">
          <%= number_with_delimiter(@monthly_total) %> <%= t("dashboard.expense_currency") %>
        </p>

        <div class="w-full bg-gray-200 rounded-full h-3 mt-4">
          <div class="bg-clay-500 h-3 rounded-full"
              style="width: <%= @expense_target > 0 ? [(@monthly_total / @expense_target.to_f * 100).round, 100].min : 0 %>%"></div>
        </div>

        <p class="text-sm text-gray-500 mt-1"><%= t("dashboard.expense_guide", amount: number_with_delimiter(@expense_target)) %></p>
      </div>
    <% end %>

    <%# Weight trend card %>
    <% if current_user.feature_health_log %>
      <div class="bg-white rounded-xl border shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-700"><%= t("dashboard.weight_card") %></h2>
          <%= ui_link_button t("health_logs.index.tab_graph"), stats_health_logs_path, variant: :compact %>
        </div>

        <!-- Weight sparkline chart (last 30 days) -->
        <% if @sparkline_any %>
          <div class="relative h-24">
            <canvas id="sparklineChart"></canvas>
          </div>
          <script>
            document.addEventListener("DOMContentLoaded", function () {
              new Chart(document.getElementById("sparklineChart").getContext("2d"), {
                type: "line",
                data: {
                  labels: <%= raw @sparkline_labels %>,
                  datasets: [{
                    data: <%= raw @sparkline_data %>,
                    borderColor: "rgb(69, 104, 194)",
                    backgroundColor: "rgba(69, 104, 194, 0.10)",
                    borderWidth: 1.5,
                    pointRadius: 2,
                    fill: true,
                    tension: 0.3
                  }]
                },
                options: {
                  responsive: true,
                  maintainAspectRatio: false,
                  plugins: { legend: { display: false }, tooltip: { callbacks: { label: c => `${c.parsed.y} kg` } } },
                  scales: {
                    x: { display: false },
                    y: { display: false }
                  }
                }
              });
            });
          </script>
          <p class="text-xs text-gray-400 text-right mt-1"><%= t("dashboard.sparkline_caption") %></p>
        <% else %>
          <p class="text-sm text-gray-400 text-center py-8"><%= t("dashboard.sparkline_none") %></p>
        <% end %>
      </div>
    <% end %>

    <%# Currently reading card %>
    <% if current_user.feature_book %>
      <div class="bg-white rounded-xl border shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-700"><%= t("dashboard.reading_card") %></h2>
          <%= ui_link_button t("books.index.title"), books_path, variant: :compact %>
        </div>

        <div class="space-y-2">
          <% if @reading_books.any? %>
            <% @reading_books.each do |book| %>
              <%= link_to book_path(book), class: "block border-b py-2 hover:bg-gray-50 transition min-w-0" do %>
                <p class="font-semibold text-gray-800 truncate"><%= book.title %></p>
                <p class="text-sm text-gray-500 truncate"><%= book.author.presence || t("shared.unknown_author") %></p>
              <% end %>
            <% end %>
          <% else %>
            <p class="text-gray-500 text-sm"><%= t("dashboard.reading_none") %></p>
          <% end %>
        </div>
      </div>
    <% end %>

  </div>
</div>
