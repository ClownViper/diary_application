<div class="max-w-4xl mx-auto pb-8 mb-10">
  <h1 class="text-2xl font-bold mb-6"><%= t("dashboard.title") %></h1>
  <%= render "shared/flash" %>

  <div class="w-full grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-2">

    <%# Today's info card (shown when diary or expense feature is enabled) %>
    <% if current_user.feature_diary || current_user.feature_expense %>
      <div class="bg-white rounded-xl shadow-sm border p-6">
        <h2 class="text-lg font-bold text-gray-700 mb-4">
          <%= t("dashboard.today_info", date: @today.strftime("%m/%d")) %>
        </h2>

        <div class="space-y-2">
          <% if current_user.feature_diary %>
            <% if @today_diary %>
              <p class="text-gray-700">
                <%= t("dashboard.today_diary_entry") %>
                <span class="font-bold text-lg"><%= @today_diary.title %></span>
              </p>
            <% else %>
              <p class="text-gray-700"><%= t("dashboard.today_diary_none") %></p>
            <% end %>
          <% end %>

          <% if current_user.feature_expense %>
            <p class="text-gray-700">
              <%= t("dashboard.today_expense") %>
              <span class="font-bold text-lg"><%= number_with_delimiter(@today_expenses.sum(:amount)) %></span> <%= t("dashboard.expense_currency") %>
            </p>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Monthly expense card %>
    <% if current_user.feature_expense %>
      <div class="bg-white rounded-xl shadow-sm border p-6">
        <h2 class="text-lg font-bold text-gray-700 mb-4"><%= t("dashboard.monthly_expense") %></h2>

        <p class="text-3xl font-extrabold text-gray-800 mb-2">
          <%= number_with_delimiter(@monthly_total) %> <%= t("dashboard.expense_currency") %>
        </p>

        <div class="w-full bg-gray-200 rounded-full h-3 mt-4">
          <div class="bg-clay-500 h-3 rounded-full"
              style="width: <%= @expense_target > 0 ? [(@monthly_total / @expense_target.to_f * 100).round, 100].min : 0 %>%"></div>
        </div>

        <p class="text-sm text-gray-500 mt-1"><%= t("dashboard.expense_guide", amount: number_with_delimiter(@expense_target)) %></p>
      </div>
    <% end %>

    <%# Today's diary card %>
    <% if current_user.feature_diary %>
      <div class="bg-white rounded-xl shadow-sm border p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-700"><%= t("dashboard.today_diary_card") %></h2>

          <% if @today_diary %>
            <%= ui_link_button t("shared.edit"), edit_diary_path(@today_diary), variant: :compact %>
          <% else %>
            <%= ui_link_button t("shared.new_record"), new_diary_path(date: @today), variant: :compact %>
          <% end %>
        </div>

        <% if @today_diary %>
          <p class="font-semibold text-gray-800"><%= @today_diary.title %></p>
          <p class="text-sm text-gray-500"><%= format_date(@today_diary.date) %></p>
          <p class="mt-2 text-gray-700 whitespace-pre-line"><%= @today_diary.body.truncate(80) %></p>
        <% else %>
          <p class="text-gray-500"><%= t("dashboard.diary_none") %></p>
        <% end %>
      </div>
    <% end %>

    <%# Today's health log card %>
    <% if current_user.feature_health_log %>
      <div class="bg-white rounded-xl shadow-sm border p-6">
        <%# Header: title + new/edit button only %>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-700"><%= t("dashboard.today_health_card") %></h2>
          <% if @today_health_log %>
            <%= ui_link_button t("shared.edit"), edit_health_log_path(@today_health_log), variant: :compact %>
          <% else %>
            <%= ui_link_button t("shared.new_record"), new_health_log_path(date: @today), variant: :compact %>
          <% end %>
        </div>

        <%# Health info %>
        <% if @today_health_log %>
          <div class="space-y-1 mb-4">
            <% if @today_health_log.weight.present? %>
              <p class="text-gray-700"><%= t("dashboard.weight_display", value: @today_health_log.weight) %></p>
            <% end %>
            <% if @today_health_log.condition.present? %>
              <p class="text-gray-700"><%= t("dashboard.condition_display", label: @today_health_log.condition_label) %></p>
            <% end %>
          </div>
        <% else %>
          <p class="text-gray-500 mb-4"><%= t("dashboard.health_none") %></p>
        <% end %>

        <%# Graph button (right-aligned) %>
        <div class="flex justify-end mb-3">
          <%= ui_link_button t("health_logs.index.tab_graph"), stats_health_logs_path, variant: :compact %>
        </div>

        <!-- Weight sparkline chart (last 30 days) -->
        <% if @sparkline_any %>
          <div class="relative h-20">
            <canvas id="sparklineChart"></canvas>
          </div>
          <script>
            document.addEventListener("DOMContentLoaded", function () {
              new Chart(document.getElementById("sparklineChart").getContext("2d"), {
                type: "line",
                data: {
                  labels: <%= raw @sparkline_labels %>,
                  datasets: [{
                    data: <%= raw @sparkline_data %>,
                    borderColor: "rgb(194, 97, 63)",
                    backgroundColor: "rgba(194, 97, 63, 0.10)",
                    borderWidth: 1.5,
                    pointRadius: 2,
                    fill: true,
                    tension: 0.3
                  }]
                },
                options: {
                  responsive: true,
                  maintainAspectRatio: false,
                  plugins: { legend: { display: false }, tooltip: { callbacks: { label: c => `${c.parsed.y} kg` } } },
                  scales: {
                    x: { display: false },
                    y: { display: false }
                  }
                }
              });
            });
          </script>
          <p class="text-xs text-gray-400 text-right mt-1"><%= t("dashboard.sparkline_caption") %></p>
        <% else %>
          <p class="text-xs text-gray-400 text-center py-4"><%= t("dashboard.sparkline_none") %></p>
        <% end %>
      </div>
    <% end %>

    <%# Today's schedule card %>
    <% if current_user.feature_schedule %>
      <div class="bg-white rounded-xl shadow-sm border p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-700"><%= t("dashboard.today_schedule_card") %></h2>
          <%= ui_link_button t("shared.new_record"), new_schedule_path(date: @today), variant: :compact %>
        </div>

        <div class="space-y-2">
          <% if @today_schedules.any? %>
            <% @today_schedules.each do |schedule| %>
              <div class="border-b py-2 flex justify-between items-center">
                <span class="font-semibold text-gray-800"><%= schedule.title %></span>
                <% if schedule.start_time.present? %>
                  <span class="text-sm text-gray-500"><%= schedule.start_time.strftime("%H:%M") %></span>
                <% end %>
              </div>
            <% end %>
          <% else %>
            <p class="text-gray-500 text-sm"><%= t("dashboard.schedule_none") %></p>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Currently reading card %>
    <% if current_user.feature_book %>
      <div class="bg-white rounded-xl shadow-sm border p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-700"><%= t("dashboard.reading_card") %></h2>
          <%= ui_link_button t("diaries.index.title"), books_path, variant: :compact %>
        </div>

        <div class="space-y-2">
          <% if @reading_books.any? %>
            <% @reading_books.each do |book| %>
              <div class="border-b py-2">
                <p class="font-semibold text-gray-800"><%= book.title %></p>
                <p class="text-sm text-gray-500"><%= book.author.presence || t("shared.unknown_author") %></p>
              </div>
            <% end %>
          <% else %>
            <p class="text-gray-500 text-sm"><%= t("dashboard.reading_none") %></p>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Mini calendar -->
    <div class="bg-white rounded-xl shadow-sm border p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-700"><%= l(@today, format: :month_only) %></h2>
        <%= ui_link_button t("dashboard.mini_calendar_btn"), calendar_path, variant: :compact %>
      </div>

      <div class="grid grid-cols-7 text-center text-sm font-semibold text-gray-600 mb-2">
        <% t("date.abbr_day_names").each_with_index do |name, i| %>
          <div class="<%= i == 0 ? 'text-red-500' : i == 6 ? 'text-blue-500' : '' %>"><%= name %></div>
        <% end %>
      </div>

      <div class="grid grid-cols-7 text-center gap-1">
        <% @first_day.wday.times do %>
          <div></div>
        <% end %>

        <% @days.each do |day| %>
          <% is_today = (day == @today) %>
          <% wday = day.wday %>

          <% text_color =
              case wday
              when 0 then "text-red-500"
              when 6 then "text-blue-500"
              else "text-gray-700"
              end
          %>

          <div class="flex items-center justify-center py-1">
            <div class="w-7 h-7 flex items-center justify-center rounded-full
                        <%= is_today ? 'bg-clay-500 text-white font-bold' : text_color %>">
              <%= day.day %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Recent expenses card %>
    <% if current_user.feature_expense %>
      <div class="bg-white rounded-xl shadow-sm border p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-700"><%= t("dashboard.recent_expense_card") %></h2>
          <%= ui_link_button t("expenses.index.title"), expenses_path, variant: :compact %>
        </div>

        <div class="space-y-3">
          <% if @recent_expenses.any? %>
            <% @recent_expenses.each do |e| %>
              <div class="border-b py-2 flex justify-between">
                <span><%= e.category&.name || t("shared.uncategorized") %></span>
                <span><%= e.amount %> <%= t("dashboard.expense_currency") %></span>
              </div>
            <% end %>
          <% else %>
            <p class="text-gray-500 text-sm"><%= t("dashboard.recent_expense_none") %></p>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Recent diary entries card %>
    <% if current_user.feature_diary %>
      <div class="bg-white rounded-xl shadow-sm border p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-700"><%= t("dashboard.recent_diary_card") %></h2>
          <%= ui_link_button t("diaries.index.title"), diaries_path, variant: :compact %>
        </div>

        <div class="space-y-3">
          <% if @recent_diaries.any? %>
            <% @recent_diaries.each do |d| %>
              <div class="border-b py-2">
                <p class="font-semibold"><%= d.title %></p>
                <p class="text-sm text-gray-600"><%= d.date %></p>
              </div>
            <% end %>
          <% else %>
            <p class="text-gray-500 text-sm"><%= t("dashboard.recent_diary_none") %></p>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
