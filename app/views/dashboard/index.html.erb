<div class="max-w-4xl mx-auto py-8 mb-10">
  <h1 class="text-2xl font-bold mb-6">ダッシュボード</h1>

  <div class="w-full grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-2">

    <!-- 今日の情報 -->
    <div class="bg-white rounded-xl shadow-sm border p-6">
      <h2 class="text-lg font-bold text-gray-700 mb-4">
        今日の情報（<%= @today.strftime("%m/%d") %>）
      </h2>

      <div class="space-y-2">
        <% if @today_diary %>
          <p class="text-green-600 font-semibold">📘 日記あり：<%= @today_diary.title %></p>
        <% else %>
          <p class="text-gray-500">📘 日記なし</p>
        <% end %>

        <p class="text-gray-700">
          💴 出費：
          <span class="font-bold text-lg"><%= number_with_delimiter(@today_expenses.sum(:amount)) %></span> 円
        </p>
      </div>
    </div>

    <!-- 今月の出費 -->
    <div class="bg-white rounded-xl shadow-sm border p-6">
      <h2 class="text-lg font-bold text-gray-700 mb-4">今月の出費</h2>

      <p class="text-3xl font-extrabold text-gray-800 mb-2">
        <%= number_with_delimiter(@monthly_total) %> 円
      </p>

      <div class="w-full bg-gray-200 rounded-full h-3 mt-4">
        <div class="bg-red-400 h-3 rounded-full"
            style="width: <%= [(@monthly_total / 150000.0 * 100).round, 100].min %>%"></div>
      </div>

      <p class="text-sm text-gray-500 mt-1">※ 目安：15万円/月</p>
    </div>

    <!-- 今日の日記 -->
    <div class="bg-white rounded-xl shadow-sm border p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-700">今日の日記</h2>

        <% if @today_diary %>
          <%= ui_link_button "編集", edit_diary_path(@today_diary), variant: :compact %>
        <% else %>
          <%= ui_link_button "追加", new_diary_path(date: @today), variant: :compact %>
        <% end %>
      </div>

      <% if @today_diary %>
        <p class="font-semibold text-gray-800"><%= @today_diary.title %></p>
        <p class="text-sm text-gray-500"><%= @today_diary.date.strftime("%Y/%m/%d") %></p>
        <p class="mt-2 text-gray-700 whitespace-pre-line"><%= @today_diary.body.truncate(80) %></p>
      <% else %>
        <p class="text-gray-500">日記はありません</p>
      <% end %>
    </div>

    <!-- ミニカレンダー -->
    <div class="bg-white rounded-xl shadow-sm border p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-700"><%= @today.strftime("%-m月") %></h2>

        <%= ui_link_button "カレンダー", calendar_path, variant: :compact %>
      </div>

      <div class="grid grid-cols-7 text-center text-sm font-semibold text-gray-600 mb-2">
        <div class="text-red-500">日</div>
        <div>月</div>
        <div>火</div>
        <div>水</div>
        <div>木</div>
        <div>金</div>
        <div class="text-blue-500">土</div>
      </div>

      <div class="grid grid-cols-7 text-center gap-1">
        <% @first_day.wday.times do %>
          <div></div>
        <% end %>

        <% @days.each do |day| %>
          <% is_today = (day == @today) %>
          <% wday = day.wday %>

          <% text_color =
              case wday
              when 0 then "text-red-500"
              when 6 then "text-blue-500"
              else "text-gray-700"
              end
          %>

          <% bg_class = is_today ? "bg-blue-500 text-white font-bold" : "" %>

          <div class="p-2 rounded-lg <%= bg_class %> <%= text_color %>">
            <%= day.day %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- 最近の出費 -->
    <div class="bg-white rounded-xl shadow-sm border p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-700">最近の出費</h2>
        <%= ui_link_button "出費一覧", expenses_path, variant: :compact %>
      </div>

      <div class="space-y-3">
        <% if @recent_expenses.any? %>
          <% @recent_expenses.each do |e| %>
            <div class="border-b py-2 flex justify-between">
              <span><%= e.category&.name || "未分類" %></span>
              <span><%= e.amount %> 円</span>
            </div>
          <% end %>
        <% else %>
          <p class="text-gray-500 text-sm">最近の出費はありません</p>
        <% end %>
      </div>
    </div>

    <!-- 最近の日記 -->
    <div class="bg-white rounded-xl shadow-sm border p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-700">最近の日記</h2>
        <%= ui_link_button "日記一覧", diaries_path, variant: :compact %>
      </div>

      <div class="space-y-3">
        <% if @recent_diaries.any? %>
          <% @recent_diaries.each do |d| %>
            <div class="border-b py-2">
              <p class="font-semibold"><%= d.title %></p>
              <p class="text-sm text-gray-600"><%= d.date %></p>
            </div>
          <% end %>
        <% else %>
          <p class="text-gray-500 text-sm">最近の日記はありません</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
