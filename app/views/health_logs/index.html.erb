<div class="max-w-4xl mx-auto pb-8 mb-10">

  <%= render "shared/page_header", title: "体調ログ", button_label: "新規作成", button_path: new_health_log_path %>

  <!-- 一覧 / グラフ タブ -->
  <div class="flex gap-2 mb-6">
    <span class="px-4 py-2 rounded-lg font-semibold text-sm bg-blue-600 text-white">一覧</span>
    <%= link_to "グラフ", stats_health_logs_path,
          class: "px-4 py-2 rounded-lg font-semibold text-sm bg-white text-gray-600 border hover:bg-gray-50 transition" %>
  </div>

  <!-- 検索フォーム -->
  <div class="mb-6 bg-white p-4 rounded-xl shadow">
    <%= form_with url: health_logs_path, method: :get, local: true, class: "grid grid-cols-1 md:grid-cols-3 gap-4" do |f| %>

      <div>
        <label class="<%= ApplicationHelper::SEARCH_LABEL_CLASS %>">キーワード</label>
        <%= f.text_field :q, value: params[:q],
              placeholder: "メモを検索",
              class: ApplicationHelper::INPUT_CLASS %>
      </div>

      <div>
        <label class="<%= ApplicationHelper::SEARCH_LABEL_CLASS %>">日付</label>
        <%= f.date_field :date, value: params[:date],
              placeholder: " ",
              class: [ApplicationHelper::INPUT_CLASS, "h-[42px] bg-white text-gray-800 appearance-none"].join(" ") %>
      </div>

      <div class="flex items-end">
        <%= f.submit "検索", class: [ui_button_classes(variant: :primary, size: :md), "w-full"].join(" ") %>
      </div>

    <% end %>
  </div>

  <!-- テーブル風一覧 -->
  <div class="bg-white rounded-xl shadow overflow-hidden">

    <div class="hidden md:grid grid-cols-4 bg-gray-100 px-4 py-2 text-sm font-semibold text-gray-700">
      <div>日付</div>
      <div>体重</div>
      <div>体調</div>
      <div class="text-right">メモ</div>
    </div>

    <% @health_logs.each do |log| %>
      <%= link_to health_log_path(log),
            class: "grid grid-cols-1 md:grid-cols-4 gap-1 px-4 py-3 border-b hover:bg-gray-50 transition" do %>

        <div class="text-gray-600">
          <%= format_date(log.date) %>
        </div>

        <div class="font-medium text-gray-900">
          <%= log.weight.present? ? "#{log.weight} kg" : "—" %>
        </div>

        <div class="text-gray-700">
          <% if log.condition.present? %>
            <span class="px-2 py-1 rounded-full text-xs font-semibold
              <%= case log.condition
                  when 1..2 then 'bg-red-100 text-red-700'
                  when 3 then 'bg-yellow-100 text-yellow-700'
                  when 4..5 then 'bg-green-100 text-green-700'
                  end %>">
              <%= log.condition_label %>
            </span>
          <% else %>
            —
          <% end %>
        </div>

        <div class="text-right text-gray-500 truncate">
          <%= log.memo.present? ? log.memo.truncate(20) : "—" %>
        </div>

      <% end %>
    <% end %>

    <%= render "shared/empty_state", message: "体調ログはありません。", inline: true if @health_logs.empty? %>

  </div>
  <%= render "shared/pagination", collection: @health_logs %>
</div>
