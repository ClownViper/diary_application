<%= render layout: "shared/form_card" do %>
  <%= form_with model: health_log, data: { turbo: false }, class: "space-y-6" do |f| %>
    <%= render "shared/form_errors", resource: health_log %>

    <div class="!mt-2">
      <%= render "shared/form_field", form: f, attr: :date, field_label: "日付", field_type: :date_field %>
    </div>

    <%= render "shared/form_field", form: f, attr: :weight, field_label: "体重 (kg)", field_type: :number_field,
          field_options: { step: 0.1, min: 0, placeholder: "例: 65.5" } %>

    <!-- 体調（1〜5のラジオボタン） -->
    <div>
      <%= f.label :condition, "体調", class: ApplicationHelper::LABEL_CLASS %>
      <div class="flex gap-3 mt-1">
        <% HealthLog::CONDITION_LABELS.each do |value, label| %>
          <label class="flex items-center gap-1 cursor-pointer">
            <%= f.radio_button :condition, value, class: "accent-blue-600" %>
            <span class="text-sm text-gray-700"><%= label %></span>
          </label>
        <% end %>
      </div>
      <% if health_log.errors[:condition].any? %>
        <p class="mt-1 text-sm text-red-600"><%= health_log.errors[:condition].first %></p>
      <% end %>
    </div>

    <%= render "shared/form_field", form: f, attr: :memo, field_label: "メモ", field_type: :text_area,
          field_options: { rows: 3, maxlength: 100, placeholder: "100文字以内" } %>

    <div>
      <%= f.submit "保存", class: ui_button_classes(variant: :primary, size: :lg) %>
    </div>
  <% end %>
<% end %>
