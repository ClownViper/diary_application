<%= render layout: "shared/form_card" do %>
  <%= form_with model: health_log, data: { turbo: false }, class: "space-y-6" do |f| %>

    <div class="!mt-2">
      <%= render "shared/form_field", form: f, attr: :date, field_type: :date_field %>
    </div>

    <%= render "shared/form_field", form: f, attr: :weight, field_label: t("health_logs.form.weight_with_unit"), field_type: :number_field,
          field_options: { step: 0.1, min: 0, placeholder: t("health_logs.form.weight_placeholder") } %>

    <!-- Condition (radio buttons 1-5) -->
    <div>
      <%= f.label :condition, t("activerecord.attributes.health_log.condition"), class: ApplicationHelper::LABEL_CLASS %>
      <div class="flex flex-col gap-2 sm:flex-row sm:gap-3 mt-1">
        <% HealthLog.condition_labels.each do |value, label| %>
          <label class="flex items-center gap-1 cursor-pointer">
            <%= f.radio_button :condition, value, class: "accent-blue-600" %>
            <span class="text-sm text-gray-700"><%= label %></span>
          </label>
        <% end %>
      </div>
      <% if health_log.errors[:condition].any? %>
        <p class="mt-1 text-sm text-red-600"><%= health_log.errors[:condition].first %></p>
      <% end %>
    </div>

    <%= render "shared/form_field", form: f, attr: :sleep_hours, field_label: t("health_logs.form.sleep_hours_with_unit"), field_type: :number_field,
          field_options: { step: 0.5, min: 0, placeholder: t("health_logs.form.sleep_hours_placeholder") } %>

    <%= render "shared/form_field", form: f, attr: :temperature, field_label: t("health_logs.form.temperature_with_unit"), field_type: :number_field,
          field_options: { step: 0.1, min: 0, placeholder: t("health_logs.form.temperature_placeholder") } %>

    <%= render "shared/form_field", form: f, attr: :memo, field_type: :text_area,
          field_options: { rows: 3, maxlength: 100, placeholder: t("health_logs.form.memo_placeholder") } %>

    <div>
      <%= f.submit t("shared.save"), class: ui_button_classes(variant: :primary, size: :lg) %>
    </div>
  <% end %>
<% end %>
